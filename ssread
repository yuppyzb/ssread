_KEY=""

read_key() {
    _KEY=""
    local c="" _read_rc=0
    # Timeout after 2s so we periodically re-render (catches pane resizes, activity updates)
    # 1s timeout: fast enough for spinner animation, light on CPU
    IFS= read -rsn1 -t 1 c 2>/dev/null || _read_rc=$?
    if (( _read_rc > 0 )) && [[ -z "$c" ]]; then
        # Timeout or signal — return empty key to trigger re-render
        return
    fi
    if [[ "$c" == $'\x1b' ]]; then
        local seq=""
        IFS= read -rsn1 -t 1 seq 2>/dev/null || true
        if [[ "$seq" == "[" ]]; then
            local code=""
            IFS= read -rsn1 -t 1 code 2>/dev/null || true
            _KEY="ESC[${code}"
        else
            _KEY="ESC"
        fi
    elif [[ "$c" == $'\t' ]]; then
        _KEY="TAB"
    elif [[ "$c" == "" ]]; then
        _KEY="ENTER"
    else
        _KEY="$c"
    fi
}

handle_search_input() {
    case "$_KEY" in
        ENTER)
            SEARCH_MODE=false
            if [[ -n "$SEARCH_QUERY" ]]; then
                SEARCH_ACTIVE="$SEARCH_QUERY"
                SELECTED=0
                SCROLL_OFFSET=0
                draw_loading
                load_sessions
                search_sessions "$SEARCH_ACTIVE"
                group_sessions
                build_display_list
            fi
            ;;
        ESC)
            SEARCH_MODE=false
            if [[ -n "$SEARCH_ACTIVE" ]]; then
                # Clear search and reload all sessions
                SEARCH_QUERY=""
                SEARCH_ACTIVE=""
                SELECTED=0
                SCROLL_OFFSET=0
                load_sessions
                group_sessions
                build_display_list
            fi
            SEARCH_QUERY=""
            ;;
        $'\x7f'|$'\b')
            SEARCH_QUERY="${SEARCH_QUERY%?}"
            ;;
        *)
            if [[ ${#_KEY} -eq 1 ]] && [[ "$_KEY" =~ [[:print:]] ]]; then
                SEARCH_QUERY="${SEARCH_QUERY}${_KEY}"
            fi
            ;;
    esac
}

handle_command_input() {
    case "$_KEY" in
        ENTER)
            COMMAND_MODE=false
            if [[ -n "$COMMAND_INPUT" ]]; then
                execute_command "$COMMAND_INPUT"
            fi
            COMMAND_INPUT=""
            ;;
        ESC)
            COMMAND_MODE=false
            COMMAND_INPUT=""
            ;;
        $'\x7f'|$'\b')
            COMMAND_INPUT="${COMMAND_INPUT%?}"
            ;;
        *)
            if [[ ${#_KEY} -eq 1 ]] && [[ "$_KEY" =~ [[:print:]] ]]; then
                COMMAND_INPUT="${COMMAND_INPUT}${_KEY}"
            fi
            ;;
    esac
}

handle_input() {
    read_key

    if $COMMAND_MODE; then
        handle_command_input
        return
    fi

    if $SEARCH_MODE; then
        handle_search_input
        return
    fi

    case "$_KEY" in
        "ESC[A"|k)
            if (( SELECTED > 0 )); then
                SELECTED=$(( SELECTED - 1 ))
            fi
            ;;
        "ESC[B"|j)
            if (( SELECTED < DISPLAY_COUNT - 1 )); then
                SELECTED=$(( SELECTED + 1 ))
            fi
            ;;
        ENTER)
            if (( DISPLAY_COUNT > 0 && SELECTED < DISPLAY_COUNT )); then
                if [[ "${DISPLAY_TYPES[$SELECTED]}" == "group" ]]; then
                    # Toggle fold on group header
                    local g="${DISPLAY_INDICES[$SELECTED]}"
                    toggle_group_fold "${GROUP_NAMES[$g]}"
                    build_display_list
                else
                    # Attach session
                    local si="${DISPLAY_INDICES[$SELECTED]}"
                    local sid="${SESSION_IDS[$si]}"
                    local cwd="${SESSION_CWDS[$si]}"
                    if [[ -n "${TMUX:-}" ]]; then
                        pane_attach_session "$sid" "$cwd"
                    else
                        launch_session_direct "$sid" "$cwd"
                    fi
                fi
            fi
            ;;
        TAB)
            if [[ -n "${TMUX:-}" && -n "$ATTACHED_SID" ]]; then
                tmux select-pane -t "$TMUX_SESSION_NAME:list.2" 2>/dev/null || true
            fi
            ;;
        f)
            local _si
            _si=$(selected_session_idx)
            if [[ -n "$_si" ]]; then
                fork_session "$_si"
            fi
            ;;
        b)
            local _si
            _si=$(selected_session_idx)
            if [[ -n "$_si" ]]; then
                toggle_bookmark "${SESSION_IDS[$_si]}"
                group_sessions
                build_display_list
            fi
            ;;
        a)
            local _si
            _si=$(selected_session_idx)
            if [[ -n "$_si" ]]; then
                toggle_archive "${SESSION_IDS[$_si]}"
                group_sessions
                build_display_list
            fi
            ;;
        q)
            exit 0
            ;;
        Q)
            # Kill all claude windows then quit
            tmux_kill_all_sessions
            exit 0
            ;;
        /)
            SEARCH_MODE=true
            SEARCH_QUERY=""
            ;;
        :)
            COMMAND_MODE=true
            COMMAND_INPUT=""
            ;;
        ESC)
            if [[ -n "$SEARCH_ACTIVE" ]]; then
                SEARCH_QUERY=""
                SEARCH_ACTIVE=""
                SELECTED=0
                SCROLL_OFFSET=0
                load_sessions
                group_sessions
                build_display_list
            elif [[ -n "$ATTACHED_SID" ]]; then
                pane_detach_current
            fi
            ;;
        r)
            SELECTED=0
            SCROLL_OFFSET=0
            ACTIVE_WINDOWS_LAST_REFRESH=0
            draw_loading
            load_sessions
            group_sessions
            build_display_list
            ;;
        g)
            SELECTED=0
            SCROLL_OFFSET=0
            ;;
        G)
            if (( DISPLAY_COUNT > 0 )); then
                SELECTED=$(( DISPLAY_COUNT - 1 ))
            fi
            ;;
    esac
}

# ── Self-Test ──────────────────────────────────────────────────────────────
run_tests() {
    local ssread_dir
    ssread_dir="$(cd "$(dirname "$0")" && pwd)"
    local test_file="$ssread_dir/tests/test_ssread.sh"

    if [[ ! -f "$test_file" ]]; then
        echo "Error: test file not found at $test_file"
        exit 1
    fi

    if ! command -v bats &>/dev/null; then
        echo "Error: bats is required to run tests."
        echo "  brew install bats-core  (macOS)"
        echo "  apt install bats        (Ubuntu/Debian)"
        exit 1
    fi

    exec bats "$test_file"
}

# ── Main ───────────────────────────────────────────────────────────────────
main() {
    # Handle --test before anything else
    if [[ "${1:-}" == "--test" ]]; then
        run_tests
    fi

    check_dependencies

    if [[ ! -d "$CLAUDE_PROJECTS_DIR" ]]; then
        echo "Error: $CLAUDE_PROJECTS_DIR not found."
        echo "No Claude Code session data available."
        exit 1
    fi

    # Bootstrap into tmux if not already inside
    ensure_tmux_session "$@"

    get_tmux_session_name
    setup_terminal
    get_dimensions
    draw_loading
    load_bookmarks
    load_archives
    load_sessions
    group_sessions
    build_display_list
    clear_screen
    setup_pane_layout

    while true; do
        render
        handle_input
    done
}

main "$@"
