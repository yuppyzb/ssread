# ── Display List (flat view of the tree) ──────────────────────────────────
# Built by build_display_list(). SELECTED indexes into this.
declare -a DISPLAY_TYPES=()    # "group" | "session"
declare -a DISPLAY_INDICES=()  # group index (for group) or session index (for session)
DISPLAY_COUNT=0

# ── Group Fold State ──────────────────────────────────────────────────────
# Stores folded group names as "|name1|name2|" for O(1) lookup.
FOLDED_GROUPS_STR="|Archive|"  # archives folded by default

is_group_folded() {
    [[ "$FOLDED_GROUPS_STR" == *"|${1}|"* ]]
}

toggle_group_fold() {
    local name="$1"
    if is_group_folded "$name"; then
        FOLDED_GROUPS_STR="${FOLDED_GROUPS_STR/"|${name}|"/"|"}"
    else
        FOLDED_GROUPS_STR="${FOLDED_GROUPS_STR}${name}|"
    fi
}

# Build flat display list from groups, respecting fold state
build_display_list() {
    DISPLAY_TYPES=()
    DISPLAY_INDICES=()

    if [[ -n "$SEARCH_ACTIVE" ]] || (( GROUP_COUNT == 0 )); then
        for (( i=0; i<SESSION_COUNT; i++ )); do
            DISPLAY_TYPES+=("session")
            DISPLAY_INDICES+=("$i")
        done
    else
        for (( g=0; g<GROUP_COUNT; g++ )); do
            DISPLAY_TYPES+=("group")
            DISPLAY_INDICES+=("$g")
            local gname="${GROUP_NAMES[$g]}"
            if ! is_group_folded "$gname"; then
                local gstart="${GROUP_STARTS[$g]}"
                local gcount="${GROUP_COUNTS[$g]}"
                for (( s=0; s<gcount; s++ )); do
                    DISPLAY_TYPES+=("session")
                    DISPLAY_INDICES+=("$(( gstart + s ))")
                done
            fi
        done
    fi
    DISPLAY_COUNT=${#DISPLAY_TYPES[@]}

    # Clamp SELECTED
    if (( SELECTED >= DISPLAY_COUNT )); then
        SELECTED=$(( DISPLAY_COUNT > 0 ? DISPLAY_COUNT - 1 : 0 ))
    fi
}

# Get session array index for current selection. Returns "" if group is selected.
selected_session_idx() {
    if (( SELECTED >= 0 && SELECTED < DISPLAY_COUNT )) && [[ "${DISPLAY_TYPES[$SELECTED]}" == "session" ]]; then
        echo "${DISPLAY_INDICES[$SELECTED]}"
    fi
}

# Detail-level fields (lazy loaded for one session at a time)
DETAIL_SID=""         # which session is currently loaded
DETAIL_LAST_MSG=""
DETAIL_MSG_COUNT=""
DETAIL_TOTAL_OUTPUT=""
DETAIL_TOOL_COUNT=""
DETAIL_TOP_TOOL=""
DETAIL_VERSION=""
DETAIL_ENTRYPOINT=""

# Group data: sessions grouped by project
declare -a GROUP_NAMES=()
declare -a GROUP_STARTS=()
declare -a GROUP_COUNTS=()
GROUP_COUNT=0

# Cache of active tmux window states (refreshed periodically)
# Uses pane_current_command to detect actual process state:
#   "claude" → session is working (show spinner)
#   anything else (sleep/bash) → session is done (show ●)
ACTIVE_WINDOWS_STR="|"    # all s:* windows
ACTIVE_WINDOWS_COUNT=0
WORKING_WINDOWS_STR="|"   # windows where claude is actively running
ACTIVE_WINDOWS_LAST_REFRESH=0

refresh_active_windows() {
    local now=${EPOCHSECONDS:-$(date +%s)}
    if (( now - ACTIVE_WINDOWS_LAST_REFRESH < 2 )); then
        return
    fi
    ACTIVE_WINDOWS_STR="|"
    ACTIVE_WINDOWS_COUNT=0
    WORKING_WINDOWS_STR="|"
    if [[ -n "${TMUX:-}" ]]; then
        local _tmux_out
        _tmux_out=$(tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name} #{pane_pid}' 2>/dev/null) || true

        # Single ps call: get pid, ppid, comm for all processes
        local _ps_out
        _ps_out=$(ps -e -o pid=,ppid=,comm= 2>/dev/null) || true

        local name pane_pid
        while IFS=' ' read -r name pane_pid; do
            if [[ "$name" == s:* ]]; then
                local sid_part="${name#s:}"
                ACTIVE_WINDOWS_STR="${ACTIVE_WINDOWS_STR}${sid_part}|"
                ACTIVE_WINDOWS_COUNT=$(( ACTIVE_WINDOWS_COUNT + 1 ))

                # Find claude child of this pane's shell
                local claude_pid
                claude_pid=$(echo "$_ps_out" | awk -v pp="$pane_pid" '$2==pp && $3=="claude" {print $1; exit}')
                if [[ -n "$claude_pid" ]]; then
                    # Claude is running. Check if it has tool children (not npm/node)
                    # to distinguish working (tool execution) from idle (prompt)
                    local has_tools
                    has_tools=$(echo "$_ps_out" | awk -v pp="$claude_pid" '$2==pp && $3!="npm" && $3!="node" {found=1; exit} END {print found+0}')
                    if (( has_tools )); then
                        WORKING_WINDOWS_STR="${WORKING_WINDOWS_STR}${sid_part}|"
                    fi
                fi
            fi
        done <<< "$_tmux_out"
    fi
    ACTIVE_WINDOWS_LAST_REFRESH=$now
}

is_session_active() {
    [[ "$ACTIVE_WINDOWS_STR" == *"|${1:0:8}|"* ]]
}

# Session has a window but claude is NOT running (done/ended)
is_session_done() {
    is_session_active "$1" && [[ "$WORKING_WINDOWS_STR" != *"|${1:0:8}|"* ]]
}

# Session has a window and claude IS running
is_session_working() {
    [[ "$WORKING_WINDOWS_STR" == *"|${1:0:8}|"* ]]
}

extract_project_name() {
    local dir_name="$1"
    local stripped="${dir_name#-Users-ted-}"
    stripped="${stripped#project-}"
    echo "$stripped" | sed 's/--/\/_/g'
}

# ── Bookmarks ─────────────────────────────────────────────────────────────
# Bookmarks are stored as session ID prefixes (first 8 chars), one per line.
BOOKMARKS_STR="|"

load_bookmarks() {
    BOOKMARKS_STR="|"
    if [[ -f "$SSREAD_BOOKMARKS_FILE" ]]; then
        local line
        while IFS= read -r line; do
            [[ -n "$line" ]] && BOOKMARKS_STR="${BOOKMARKS_STR}${line}|"
        done < "$SSREAD_BOOKMARKS_FILE"
    fi
}

is_bookmarked() {
    [[ "$BOOKMARKS_STR" == *"|${1:0:8}|"* ]]
}

toggle_bookmark() {
    local sid="$1"
    local sid_short="${sid:0:8}"
    if is_bookmarked "$sid"; then
        # Remove bookmark
        local new_str="|"
        local entry
        while IFS='|' read -r -d '|' entry; do
            [[ -n "$entry" && "$entry" != "$sid_short" ]] && new_str="${new_str}${entry}|"
        done <<< "${BOOKMARKS_STR:1}"
        BOOKMARKS_STR="$new_str"
    else
        # Add bookmark
        BOOKMARKS_STR="${BOOKMARKS_STR}${sid_short}|"
    fi
    # Persist to file
    local entries="${BOOKMARKS_STR//|/$'\n'}"
    printf '%s' "$entries" | grep -v '^$' > "$SSREAD_BOOKMARKS_FILE" 2>/dev/null || true
}

# ── Archives ──────────────────────────────────────────────────────────────
# Archived sessions are hidden from the main list and bookmarks.
# Stored as session ID prefixes (first 8 chars), one per line.
ARCHIVES_STR="|"
# Archive fold state is managed by FOLDED_GROUPS_STR (default: folded)

load_archives() {
    ARCHIVES_STR="|"
    if [[ -f "$SSREAD_ARCHIVES_FILE" ]]; then
        local line
        while IFS= read -r line; do
            [[ -n "$line" ]] && ARCHIVES_STR="${ARCHIVES_STR}${line}|"
        done < "$SSREAD_ARCHIVES_FILE"
    fi
}

is_archived() {
    [[ "$ARCHIVES_STR" == *"|${1:0:8}|"* ]]
}

toggle_archive() {
    local sid="$1"
    local sid_short="${sid:0:8}"
    if is_archived "$sid"; then
        # Unarchive
        local new_str="|"
        local entry
        while IFS='|' read -r -d '|' entry; do
            [[ -n "$entry" && "$entry" != "$sid_short" ]] && new_str="${new_str}${entry}|"
        done <<< "${ARCHIVES_STR:1}"
        ARCHIVES_STR="$new_str"
    else
        # Archive — also remove bookmark if any
        ARCHIVES_STR="${ARCHIVES_STR}${sid_short}|"
        if is_bookmarked "$sid"; then
            toggle_bookmark "$sid"
        fi
    fi
    # Persist to file
    local entries="${ARCHIVES_STR//|/$'\n'}"
    printf '%s' "$entries" | grep -v '^$' > "$SSREAD_ARCHIVES_FILE" 2>/dev/null || true
}

load_sessions() {
    SESSION_FILES=()
    SESSION_IDS=()
    SESSION_ELAPSED=()
    SESSION_DIRS=()
    SESSION_TIMESTAMPS=()
    SESSION_PROJECTS=()
    SESSION_BRANCHES=()
    SESSION_CWDS=()
    SESSION_EPOCH=()
    SESSION_FIRST_MSG=()
    SESSION_MODELS=()
    SESSION_CTX=()
    SESSION_FORK_FROM=()
    SESSION_MODEL_SHORT=()
    SESSION_CTX_SHORT=()
    SESSION_COUNT=0
    DETAIL_SID=""  # invalidate cached detail

    local tmpfile
    tmpfile=$(mktemp)

    find "$CLAUDE_PROJECTS_DIR" -maxdepth 2 -name "*.jsonl" ! -path "*/subagents/*" -print0 2>/dev/null \
        | xargs -0 ls -t 2>/dev/null > "$tmpfile" || true

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue

        local dir_name
        dir_name=$(basename "$(dirname "$filepath")")
        local file_name
        file_name=$(basename "$filepath" .jsonl)

        # Compact load: first user line only (has sid, cwd, branch, ts, msg)
        local first_user_line
        first_user_line=$(grep -m1 '"type":"user"' "$filepath" 2>/dev/null) || continue
        [[ -z "$first_user_line" ]] && continue

        local user_data
        user_data=$(printf '%s' "$first_user_line" | jq -r '{
            sid: (.sessionId // ""),
            ts: (.timestamp // ""),
            cwd: (.cwd // ""),
            branch: (.gitBranch // ""),
            msg: ((.message.content // "") | if type == "string" then . elif type == "array" then [.[] | if .type == "tool_result" then (.content | if type == "string" then . elif type == "array" then [.[] | select(.type == "text") | .text] | join(" ") else "" end) elif .type == "text" then .text else "" end] | join(" ") else "" end | gsub("<[^>]+>"; "") | gsub("\\s+"; " ") | ltrimstr(" ") | .[0:100])
        }' 2>/dev/null) || continue

        local sid ts cwd branch first_msg
        sid=$(printf '%s' "$user_data" | jq -r '.sid')
        ts=$(printf '%s' "$user_data" | jq -r '.ts')
        cwd=$(printf '%s' "$user_data" | jq -r '.cwd')
        branch=$(printf '%s' "$user_data" | jq -r '.branch')
        first_msg=$(printf '%s' "$user_data" | jq -r '.msg')

        [[ -z "$sid" || "$sid" == "null" ]] && sid="$file_name"
        [[ "$ts" == "null" ]] && ts=""
        [[ "$cwd" == "null" ]] && cwd=""
        [[ "$branch" == "null" ]] && branch=""
        [[ "$first_msg" == "null" ]] && first_msg=""

        # Compact load: last assistant line (has model, usage/context)
        local model="" ctx=0
        local last_asst_line
        last_asst_line=$(grep '"type":"assistant"' "$filepath" 2>/dev/null | tail -1) || true
        if [[ -n "$last_asst_line" ]]; then
            local asst_data
            asst_data=$(printf '%s' "$last_asst_line" | jq -r '{
                model: (.message.model // ""),
                ctx: ((.message.usage.input_tokens // 0) + (.message.usage.cache_creation_input_tokens // 0) + (.message.usage.cache_read_input_tokens // 0))
            }' 2>/dev/null) || true
            if [[ -n "$asst_data" ]]; then
                model=$(printf '%s' "$asst_data" | jq -r '.model')
                ctx=$(printf '%s' "$asst_data" | jq -r '.ctx')
                [[ "$model" == "null" ]] && model=""
                [[ "$ctx" == "null" ]] && ctx=0
            fi
        fi

        local epoch=0
        if [[ -n "$ts" ]]; then
            epoch=$(iso_to_epoch "$ts")
        fi

        local project_name
        project_name=$(extract_project_name "$dir_name")

        # Detect fork marker: [forked-from:XXXXXXXX]
        local fork_from=""
        if [[ "$first_msg" =~ ^\[forked-from:([a-f0-9]+)\] ]]; then
            fork_from="${BASH_REMATCH[1]}"
            # Strip marker + preamble, show the context line
            first_msg=$(printf '%s' "$first_msg" | sed 's/^\[forked-from:[a-f0-9]*\] *//')
            # Try to extract just the context part
            local ctx_line
            ctx_line=$(printf '%s' "$first_msg" | sed -n 's/.*작업 컨텍스트: *//p')
            if [[ -n "$ctx_line" ]]; then
                first_msg="$ctx_line"
            fi
        fi

        SESSION_FILES+=("$filepath")
        SESSION_IDS+=("$sid")
        SESSION_TIMESTAMPS+=("$ts")
        SESSION_DIRS+=("$dir_name")
        SESSION_PROJECTS+=("$project_name")
        SESSION_BRANCHES+=("$branch")
        SESSION_CWDS+=("$cwd")
        SESSION_EPOCH+=("$epoch")
        SESSION_FIRST_MSG+=("$first_msg")
        SESSION_MODELS+=("$model")
        SESSION_CTX+=("$ctx")
        SESSION_FORK_FROM+=("$fork_from")
        SESSION_MODEL_SHORT+=("$(format_model_short "$model")")
        SESSION_CTX_SHORT+=("$(format_tokens "$ctx")")

        if [[ -n "$ts" && "$epoch" -gt 0 ]]; then
            SESSION_ELAPSED+=("$(format_elapsed "$epoch")")
        else
            SESSION_ELAPSED+=("?")
        fi

        SESSION_COUNT=$(( SESSION_COUNT + 1 ))
    done < "$tmpfile"

    rm -f "$tmpfile"
}

# ── Lazy Detail Loading ───────────────────────────────────────────────────
# Full parse of a single session file. Called when selection changes.
format_model_short() {
    local m="$1"
    case "$m" in
        *opus*)   echo "opus" ;;
        *sonnet*) echo "sonnet" ;;
        *haiku*)  echo "haiku" ;;
        *)        echo "${m:0:12}" ;;
    esac
}

format_tokens() {
    local t="$1"
    if (( t >= 1000000 )); then
        echo "$(( t / 1000000 )).$(( (t % 1000000) / 100000 ))M"
    elif (( t >= 1000 )); then
        echo "$(( t / 1000 ))K"
    else
        echo "$t"
    fi
}

load_session_detail() {
    local idx="$1"
    local sid="${SESSION_IDS[$idx]}"

    # Skip if already loaded for this session
    if [[ "$DETAIL_SID" == "$sid" ]]; then
        return
    fi

    DETAIL_SID="$sid"
    DETAIL_LAST_MSG=""
    DETAIL_MSG_COUNT=""
    DETAIL_TOTAL_OUTPUT=""
    DETAIL_TOOL_COUNT=""
    DETAIL_TOP_TOOL=""
    DETAIL_VERSION=""
    DETAIL_ENTRYPOINT=""

    local filepath="${SESSION_FILES[$idx]}"
    [[ ! -f "$filepath" ]] && return

    local detail
    detail=$(jq -s '{
        last_msg: ([.[] | select(.type == "user") | .message.content // ""] | last // "" | if type == "string" then . elif type == "array" then [.[] | if .type == "tool_result" then (.content | if type == "string" then . elif type == "array" then [.[] | select(.type == "text") | .text] | join(" ") else "" end) elif .type == "text" then .text else "" end] | join(" ") else "" end | gsub("<[^>]+>"; "") | gsub("\\s+"; " ") | ltrimstr(" ") | .[0:120]),
        msg_count: ([.[] | select(.type == "user")] | length),
        total_output: ([.[] | select(.type == "assistant") | .message.usage.output_tokens // 0] | add // 0),
        tool_count: ([.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use")] | length),
        top_tool: ([.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use") | .name] | group_by(.) | sort_by(-length) | .[0][0] // "-"),
        version: ([.[] | select(.type == "user") | .version // ""] | .[0] // ""),
        entrypoint: ([.[] | select(.type == "user") | .entrypoint // ""] | .[0] // "")
    }' "$filepath" 2>/dev/null) || return

    DETAIL_LAST_MSG=$(printf '%s' "$detail" | jq -r '.last_msg')
    DETAIL_MSG_COUNT=$(printf '%s' "$detail" | jq -r '.msg_count')
    DETAIL_TOTAL_OUTPUT=$(printf '%s' "$detail" | jq -r '.total_output')
    DETAIL_TOOL_COUNT=$(printf '%s' "$detail" | jq -r '.tool_count')
    DETAIL_TOP_TOOL=$(printf '%s' "$detail" | jq -r '.top_tool')
    DETAIL_VERSION=$(printf '%s' "$detail" | jq -r '.version')
    DETAIL_ENTRYPOINT=$(printf '%s' "$detail" | jq -r '.entrypoint')

    if [[ "$DETAIL_LAST_MSG" == "null" ]]; then DETAIL_LAST_MSG=""; fi
    if [[ "$DETAIL_TOP_TOOL" == "null" ]]; then DETAIL_TOP_TOOL="-"; fi
}

# ── Group sessions by project ─────────────────────────────────────────────
# Reorders SESSION_* arrays so sessions in the same project are contiguous.
# Groups are sorted by the most recent session within each group (already
# the first occurrence since sessions are loaded newest-first).

group_sessions() {
    GROUP_NAMES=()
    GROUP_STARTS=()
    GROUP_COUNTS=()
    GROUP_COUNT=0

    if (( SESSION_COUNT == 0 )); then
        return
    fi

    # Phase 1: Collect bookmarked sessions first (★ Bookmarks group)
    # Archived sessions are excluded from bookmarks and project groups.
    local -a order=()  # maps: flat index in new order → original index
    local bookmark_count=0
    for (( i=0; i<SESSION_COUNT; i++ )); do
        if is_bookmarked "${SESSION_IDS[$i]}" && ! is_archived "${SESSION_IDS[$i]}"; then
            order+=("$i")
            bookmark_count=$(( bookmark_count + 1 ))
        fi
    done
    if (( bookmark_count > 0 )); then
        GROUP_NAMES+=("Bookmarks")
        GROUP_STARTS+=(0)
        GROUP_COUNTS+=("$bookmark_count")
        GROUP_COUNT=$(( GROUP_COUNT + 1 ))
    fi

    # Phase 2: Collect unique project names in first-seen order (= most-recent-first)
    local -a seen_projects=()
    for (( i=0; i<SESSION_COUNT; i++ )); do
        if is_archived "${SESSION_IDS[$i]}"; then continue; fi
        local proj="${SESSION_PROJECTS[$i]}"
        local found=false
        for sp in "${seen_projects[@]+"${seen_projects[@]}"}"; do
            if [[ "$sp" == "$proj" ]]; then
                found=true
                break
            fi
        done
        if ! $found; then
            seen_projects+=("$proj")
        fi
    done

    # Phase 3: Build project groups (non-bookmarked, non-archived sessions)
    for proj in "${seen_projects[@]}"; do
        local start=${#order[@]}
        local count=0
        for (( i=0; i<SESSION_COUNT; i++ )); do
            if [[ "${SESSION_PROJECTS[$i]}" == "$proj" ]] && ! is_bookmarked "${SESSION_IDS[$i]}" && ! is_archived "${SESSION_IDS[$i]}"; then
                order+=("$i")
                count=$(( count + 1 ))
            fi
        done
        if (( count > 0 )); then
            GROUP_NAMES+=("$proj")
            GROUP_STARTS+=("$start")
            GROUP_COUNTS+=("$count")
            GROUP_COUNT=$(( GROUP_COUNT + 1 ))
        fi
    done

    # Phase 4: Collect archived sessions at the end
    local archive_start=${#order[@]}
    local archive_count=0
    for (( i=0; i<SESSION_COUNT; i++ )); do
        if is_archived "${SESSION_IDS[$i]}"; then
            order+=("$i")
            archive_count=$(( archive_count + 1 ))
        fi
    done
    if (( archive_count > 0 )); then
        GROUP_NAMES+=("Archive")
        GROUP_STARTS+=("$archive_start")
        GROUP_COUNTS+=("$archive_count")
        GROUP_COUNT=$(( GROUP_COUNT + 1 ))
    fi

    # Reorder all SESSION_* arrays according to order[]
    local -a nw_FILES=() nw_IDS=() nw_ELAPSED=() nw_DIRS=()
    local -a nw_TIMESTAMPS=() nw_PROJECTS=() nw_BRANCHES=()
    local -a nw_FIRST_MSG=() nw_CWDS=() nw_EPOCH=()
    local -a nw_MODELS=() nw_CTX=() nw_FORK_FROM=()
    local -a nw_MODEL_SHORT=() nw_CTX_SHORT=()

    for idx in "${order[@]}"; do
        nw_FILES+=("${SESSION_FILES[$idx]}")
        nw_IDS+=("${SESSION_IDS[$idx]}")
        nw_ELAPSED+=("${SESSION_ELAPSED[$idx]}")
        nw_DIRS+=("${SESSION_DIRS[$idx]}")
        nw_TIMESTAMPS+=("${SESSION_TIMESTAMPS[$idx]}")
        nw_PROJECTS+=("${SESSION_PROJECTS[$idx]}")
        nw_BRANCHES+=("${SESSION_BRANCHES[$idx]}")
        nw_FIRST_MSG+=("${SESSION_FIRST_MSG[$idx]}")
        nw_CWDS+=("${SESSION_CWDS[$idx]}")
        nw_EPOCH+=("${SESSION_EPOCH[$idx]}")
        nw_MODELS+=("${SESSION_MODELS[$idx]}")
        nw_CTX+=("${SESSION_CTX[$idx]}")
        nw_FORK_FROM+=("${SESSION_FORK_FROM[$idx]}")
        nw_MODEL_SHORT+=("${SESSION_MODEL_SHORT[$idx]}")
        nw_CTX_SHORT+=("${SESSION_CTX_SHORT[$idx]}")
    done

    SESSION_FILES=("${nw_FILES[@]}")
    SESSION_IDS=("${nw_IDS[@]}")
    SESSION_ELAPSED=("${nw_ELAPSED[@]}")
    SESSION_DIRS=("${nw_DIRS[@]}")
    SESSION_TIMESTAMPS=("${nw_TIMESTAMPS[@]}")
    SESSION_PROJECTS=("${nw_PROJECTS[@]}")
    SESSION_BRANCHES=("${nw_BRANCHES[@]}")
    SESSION_FIRST_MSG=("${nw_FIRST_MSG[@]}")
    SESSION_CWDS=("${nw_CWDS[@]}")
    SESSION_EPOCH=("${nw_EPOCH[@]}")
    SESSION_MODELS=("${nw_MODELS[@]}")
    SESSION_CTX=("${nw_CTX[@]}")
    SESSION_FORK_FROM=("${nw_FORK_FROM[@]}")
    SESSION_MODEL_SHORT=("${nw_MODEL_SHORT[@]}")
    SESSION_CTX_SHORT=("${nw_CTX_SHORT[@]}")
}

# ── Search with BM25 scoring ──────────────────────────────────────────────
# Searches all user messages in each session's .jsonl file.
# Scores results using simplified BM25: TF * IDF component.
# Results are sorted by score descending; non-matching sessions are hidden.

search_sessions() {
    local query="$1"
    if [[ -z "$query" ]]; then
        return
    fi

    local query_lower
    query_lower=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')

    # Split query into terms
    local -a terms=()
    for word in $query_lower; do
        [[ -n "$word" ]] && terms+=("$word")
    done
    if [[ ${#terms[@]} -eq 0 ]]; then
        return
    fi

    local total_docs=$SESSION_COUNT
    if (( total_docs == 0 )); then
        return
    fi

    # For each session, compute BM25 score by searching full .jsonl content
    local -a scored_indices=()
    local -a scored_values=()
    local k1=1200  # BM25 k1 * 1000 (integer math, 1.2 → 1200)
    local b=750    # BM25 b * 1000 (0.75 → 750)

    # Compute average document length (word count of all user messages)
    local total_words=0
    local -a doc_lengths=()
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local wc
        wc=$(jq -s -r '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | split(" ") | length' \
            "${SESSION_FILES[$i]}" 2>/dev/null) || wc=0
        doc_lengths+=("$wc")
        total_words=$(( total_words + wc ))
    done
    local avg_dl=$(( total_words / (total_docs > 0 ? total_docs : 1) ))
    (( avg_dl == 0 )) && avg_dl=1

    # Count document frequency for each term (how many sessions contain it)
    local -a df=()
    for (( t=0; t<${#terms[@]}; t++ )); do
        local term_df=0
        for (( i=0; i<SESSION_COUNT; i++ )); do
            if jq -s -e --arg q "${terms[$t]}" \
                '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | ascii_downcase | test($q)' \
                "${SESSION_FILES[$i]}" >/dev/null 2>&1; then
                term_df=$(( term_df + 1 ))
            fi
        done
        df+=("$term_df")
    done

    # Score each session
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local score=0
        local dl="${doc_lengths[$i]}"
        local matched=false

        # Get all user message text for this session (lowercase)
        local all_text
        all_text=$(jq -s -r '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | ascii_downcase' \
            "${SESSION_FILES[$i]}" 2>/dev/null) || all_text=""

        for (( t=0; t<${#terms[@]}; t++ )); do
            local term="${terms[$t]}"
            local tdf="${df[$t]}"

            # Term frequency: count occurrences
            local tf=0
            if [[ -n "$all_text" ]]; then
                # Count non-overlapping occurrences
                local stripped="${all_text//$term/}"
                local term_len=${#term}
                if (( term_len > 0 )); then
                    tf=$(( (${#all_text} - ${#stripped}) / term_len ))
                fi
            fi

            if (( tf > 0 )); then
                matched=true

                # IDF = ln((N - df + 0.5) / (df + 0.5)) * 1000
                # Simplified: higher when term is rarer
                local idf
                if (( tdf == 0 )); then
                    idf=1000
                else
                    # (N - df) / df * 1000 as approximation
                    idf=$(( (total_docs - tdf) * 1000 / tdf ))
                fi
                (( idf < 100 )) && idf=100

                # BM25 TF component: tf * (k1 + 1000) / (tf * 1000 + k1 * (1000 - b + b * dl * 1000 / avg_dl) / 1000)
                # Simplified integer approximation:
                local norm=$(( 1000 - b + b * dl / avg_dl ))
                local denom=$(( tf * 1000 + k1 * norm / 1000 ))
                local tf_score=0
                if (( denom > 0 )); then
                    tf_score=$(( tf * (k1 + 1000) * 1000 / denom ))
                fi

                score=$(( score + tf_score * idf / 1000 ))
            fi
        done

        if $matched; then
            scored_indices+=("$i")
            scored_values+=("$score")
        fi
    done

    # Sort by score descending — rebuild arrays in score order
    local count=${#scored_indices[@]}
    if (( count == 0 )); then
        SESSION_FILES=()
        SESSION_IDS=()
        SESSION_ELAPSED=()
        SESSION_DIRS=()
        SESSION_TIMESTAMPS=()
        SESSION_PROJECTS=()
        SESSION_BRANCHES=()
        SESSION_FIRST_MSG=()
        SESSION_CWDS=()
        SESSION_EPOCH=()
        SESSION_MODELS=()
        SESSION_CTX=()
        SESSION_FORK_FROM=()
        SESSION_MODEL_SHORT=()
        SESSION_CTX_SHORT=()
        SESSION_COUNT=0
        return
    fi

    # Bubble sort indices by score (small N, fine for ~100 sessions)
    for (( a=0; a<count-1; a++ )); do
        for (( c=0; c<count-a-1; c++ )); do
            if (( scored_values[c] < scored_values[c+1] )); then
                local tmp_i="${scored_indices[$c]}"
                scored_indices[$c]="${scored_indices[$((c+1))]}"
                scored_indices[$((c+1))]="$tmp_i"
                local tmp_s="${scored_values[$c]}"
                scored_values[$c]="${scored_values[$((c+1))]}"
                scored_values[$((c+1))]="$tmp_s"
            fi
        done
    done

    # Rebuild arrays in sorted order
    local -a new_FILES=() new_IDS=() new_ELAPSED=() new_DIRS=()
    local -a new_TIMESTAMPS=() new_PROJECTS=() new_BRANCHES=()
    local -a new_FIRST_MSG=() new_CWDS=() new_EPOCH=()
    local -a new_MODELS=() new_CTX=() new_FORK_FROM=()
    local -a new_MODEL_SHORT=() new_CTX_SHORT=()

    for (( x=0; x<count; x++ )); do
        local idx="${scored_indices[$x]}"
        new_FILES+=("${SESSION_FILES[$idx]}")
        new_IDS+=("${SESSION_IDS[$idx]}")
        new_ELAPSED+=("${SESSION_ELAPSED[$idx]}")
        new_DIRS+=("${SESSION_DIRS[$idx]}")
        new_TIMESTAMPS+=("${SESSION_TIMESTAMPS[$idx]}")
        new_PROJECTS+=("${SESSION_PROJECTS[$idx]}")
        new_BRANCHES+=("${SESSION_BRANCHES[$idx]}")
        new_FIRST_MSG+=("${SESSION_FIRST_MSG[$idx]}")
        new_CWDS+=("${SESSION_CWDS[$idx]}")
        new_EPOCH+=("${SESSION_EPOCH[$idx]}")
        new_MODELS+=("${SESSION_MODELS[$idx]}")
        new_CTX+=("${SESSION_CTX[$idx]}")
        new_FORK_FROM+=("${SESSION_FORK_FROM[$idx]}")
        new_MODEL_SHORT+=("${SESSION_MODEL_SHORT[$idx]}")
        new_CTX_SHORT+=("${SESSION_CTX_SHORT[$idx]}")
    done

    SESSION_FILES=("${new_FILES[@]}")
    SESSION_IDS=("${new_IDS[@]}")
    SESSION_ELAPSED=("${new_ELAPSED[@]}")
    SESSION_DIRS=("${new_DIRS[@]}")
    SESSION_TIMESTAMPS=("${new_TIMESTAMPS[@]}")
    SESSION_PROJECTS=("${new_PROJECTS[@]}")
    SESSION_BRANCHES=("${new_BRANCHES[@]}")
    SESSION_FIRST_MSG=("${new_FIRST_MSG[@]}")
    SESSION_CWDS=("${new_CWDS[@]}")
    SESSION_EPOCH=("${new_EPOCH[@]}")
    SESSION_MODELS=("${new_MODELS[@]}")
    SESSION_CTX=("${new_CTX[@]}")
    SESSION_FORK_FROM=("${new_FORK_FROM[@]}")
    SESSION_MODEL_SHORT=("${new_MODEL_SHORT[@]}")
    SESSION_CTX_SHORT=("${new_CTX_SHORT[@]}")
    SESSION_COUNT=$count
}

# ── Fork Session ───────────────────────────────────────────────────────────
fork_session() {
    local idx="$1"
    local parent_sid="${SESSION_IDS[$idx]}"
    local parent_sid_short="${parent_sid:0:8}"
    local cwd="${SESSION_CWDS[$idx]}"

    local cd_cmd=""
    if [[ -n "$cwd" && -d "$cwd" ]]; then
        cd_cmd="cd $(printf '%q' "$cwd") && "
    fi

    if [[ -z "${TMUX:-}" ]]; then
        # Non-tmux fallback: direct launch
        tput rmcup; tput cnorm
        if [[ -n "$ORIG_STTY" ]]; then stty "$ORIG_STTY" 2>/dev/null || true; fi
        clear_screen
        if [[ -n "$cwd" && -d "$cwd" ]]; then cd "$cwd"; fi
        set +e
        claude --resume "$parent_sid" --fork-session
        set -e
        tput smcup; tput civis; stty -echo -icanon min 1 time 0
        clear_screen
        return
    fi

    pane_detach_current
    local win_name="s:f${parent_sid_short}"
    tmux new-window -d -t "$TMUX_SESSION_NAME" -n "$win_name" \
        "${cd_cmd}claude --resume '${parent_sid}' --fork-session; trap '' INT HUP; tput civis 2>/dev/null; printf '\\033[H\\033[2J\\n\\033[90m  No session attached\\n\\n  Press Enter on a session to attach\\033[0m'; tmux select-pane -t '${TMUX_SESSION_NAME}:list.0' 2>/dev/null; while true; do sleep 86400; done"
    tmux swap-pane -s "$TMUX_SESSION_NAME:list.2" -t "$TMUX_SESSION_NAME:$win_name.0" 2>/dev/null || true
    ATTACHED_SID="fork:${parent_sid_short}"
    tmux select-pane -t "$TMUX_SESSION_NAME:list.2" 2>/dev/null || true
    REFRESH_AFTER_CYCLES=2
}

# ── Command Mode ───────────────────────────────────────────────────────────
set_status_msg() {
    STATUS_MSG="$1"
    STATUS_MSG_EXPIRE=$(( ${EPOCHSECONDS:-$(date +%s)} + 3 ))
}

# Launch a brand-new claude session
cmd_new_session() {
    local root="" prompt="" branch=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root|-r)
                if [[ -z "${2:-}" ]]; then
                    set_status_msg "Error: --root requires a path"
                    return 1
                fi
                root="$2"; shift 2 ;;
            --prompt|-p)
                if [[ -z "${2:-}" ]]; then
                    set_status_msg "Error: --prompt requires a value"
                    return 1
                fi
                prompt="$2"; shift 2 ;;
            --branch|-b)
                if [[ -z "${2:-}" ]]; then
                    set_status_msg "Error: --branch requires a value"
                    return 1
                fi
                branch="$2"; shift 2 ;;
            *)
                set_status_msg "Error: unknown option: $1"
                return 1 ;;
        esac
    done

    # Validate root
    if [[ -z "$root" ]]; then
        set_status_msg "Error: --root is required"
        return 1
    fi

    # Expand ~ manually
    if [[ "$root" == "~"* ]]; then
        root="${HOME}${root:1}"
    fi

    if [[ ! -d "$root" ]]; then
        set_status_msg "Error: directory not found: $root"
        return 1
    fi

    # Validate branch
    if [[ -n "$branch" ]]; then
        if [[ ! -d "$root/.git" ]] && ! git -C "$root" rev-parse --git-dir &>/dev/null; then
            set_status_msg "Error: not a git repository: $root"
            return 1
        fi
        if ! git -C "$root" rev-parse --verify "$branch" &>/dev/null; then
            set_status_msg "Error: branch not found: $branch"
            return 1
        fi
    fi

    # Build command
    local cd_cmd="cd $(printf '%q' "$root") && "
    local branch_cmd=""
    if [[ -n "$branch" ]]; then
        branch_cmd="git checkout $(printf '%q' "$branch") && "
    fi

    local claude_cmd="claude"
    if [[ -n "$prompt" ]]; then
        local prompt_file="/tmp/ssread_new_$$_$(date +%s)"
        printf '%s' "$prompt" > "$prompt_file"
        claude_cmd="claude \"\$(cat '${prompt_file}')\" ; rm -f '${prompt_file}'"
    fi

    local win_name="new"
    if [[ -n "$branch" ]]; then
        win_name="${branch:0:16}"
    fi

    if [[ -z "${TMUX:-}" ]]; then
        tput rmcup; tput cnorm
        if [[ -n "$ORIG_STTY" ]]; then stty "$ORIG_STTY" 2>/dev/null || true; fi
        clear_screen
        cd "$root"
        if [[ -n "$branch" ]]; then git checkout "$branch"; fi
        set +e
        if [[ -n "$prompt" ]]; then
            claude "$prompt"
        else
            claude
        fi
        set -e
        tput smcup; tput civis; stty -echo -icanon min 1 time 0
        clear_screen
    else
        pane_detach_current
        local pane_win_name="s:${win_name}"
        tmux new-window -d -t "$TMUX_SESSION_NAME" -n "$pane_win_name" \
            "${cd_cmd}${branch_cmd}${claude_cmd}; trap '' INT HUP; tput civis 2>/dev/null; printf '\\033[H\\033[2J\\n\\033[90m  No session attached\\n\\n  Press Enter on a session to attach\\033[0m'; tmux select-pane -t '${TMUX_SESSION_NAME}:list.0' 2>/dev/null; while true; do sleep 86400; done"
        tmux swap-pane -s "$TMUX_SESSION_NAME:list.2" -t "$TMUX_SESSION_NAME:$pane_win_name.0" 2>/dev/null || true
        ATTACHED_SID="new:${win_name}"
        tmux select-pane -t "$TMUX_SESSION_NAME:list.2" 2>/dev/null || true
    fi

    set_status_msg "New session launched in $root"
    # Defer session list reload — Claude needs time to create the .jsonl file
    REFRESH_AFTER_CYCLES=2
}

execute_command() {
    local input="$1"

    # Tokenize respecting quoted strings
    local -a tokens=()
    local token="" in_quote="" quote_char=""
    local i=0
    while (( i < ${#input} )); do
        local ch="${input:$i:1}"
        if [[ -n "$in_quote" ]]; then
            if [[ "$ch" == "$quote_char" ]]; then
                in_quote=""
            else
                token+="$ch"
            fi
        elif [[ "$ch" == '"' || "$ch" == "'" ]]; then
            in_quote=1
            quote_char="$ch"
        elif [[ "$ch" == " " ]]; then
            if [[ -n "$token" ]]; then
                tokens+=("$token")
                token=""
            fi
        else
            token+="$ch"
        fi
        (( i++ ))
    done
    [[ -n "$token" ]] && tokens+=("$token")

    if [[ ${#tokens[@]} -eq 0 ]]; then
        return
    fi

    local cmd="${tokens[0]}"
    local args=("${tokens[@]:1}")

    case "$cmd" in
        new)
            cmd_new_session "${args[@]+"${args[@]}"}"
            ;;
        *)
            set_status_msg "Unknown command: $cmd"
            ;;
    esac
}

# ── Session Launch (fallback for non-tmux) ─────────────────────────────────
launch_session_direct() {
    local sid="$1"
