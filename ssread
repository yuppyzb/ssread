    clear_screen
}

# ── Drawing ────────────────────────────────────────────────────────────────
CACHED_BORDER=""
CACHED_BORDER_ROWS=0
CACHED_BORDER_COLS=0
CACHED_BORDER_RW=0  # RIGHT_WIDTH when border was cached

_repeat_char() {
    local count="$1" char="$2"
    local pad
    printf -v pad '%*s' "$count" ''
    printf '%s' "${pad// /$char}"
}

draw_border() {
    if (( TERM_ROWS == CACHED_BORDER_ROWS && TERM_COLS == CACHED_BORDER_COLS && RIGHT_WIDTH == CACHED_BORDER_RW )); then
        printf '%s' "$CACHED_BORDER"
        return
    fi

    local buf=""
    buf+=$(move_to 1 1)
    buf+="┌"
    buf+=$(_repeat_char "$LEFT_WIDTH" "─")
    if (( RIGHT_WIDTH > 0 )); then
        buf+="┬"
        buf+=$(_repeat_char "$RIGHT_WIDTH" "─")
    fi
    buf+="┐"

    local r
    for (( r=2; r<=TERM_ROWS-2; r++ )); do
        buf+=$(move_to "$r" 1)"│"
        if (( RIGHT_WIDTH > 0 )); then
            buf+=$(move_to "$r" $(( LEFT_WIDTH + 2 )))"│"
        fi
        buf+=$(move_to "$r" "$TERM_COLS")"│"
    done

    buf+=$(move_to $(( TERM_ROWS - 1 )) 1)
    buf+="└"
    buf+=$(_repeat_char "$LEFT_WIDTH" "─")
    if (( RIGHT_WIDTH > 0 )); then
        buf+="┴"
        buf+=$(_repeat_char "$RIGHT_WIDTH" "─")
    fi
    buf+="┘"

    CACHED_BORDER="$buf"
    CACHED_BORDER_ROWS=$TERM_ROWS
    CACHED_BORDER_COLS=$TERM_COLS
    CACHED_BORDER_RW=$RIGHT_WIDTH
    printf '%s' "$buf"
}

draw_left_header() {
    local active_count=${ACTIVE_WINDOWS_COUNT:-0}
    # Count non-archived sessions for display
    local visible_count=0
    for (( _h=0; _h<SESSION_COUNT; _h++ )); do
        is_archived "${SESSION_IDS[$_h]}" || visible_count=$(( visible_count + 1 ))
    done
    local title
    if [[ -n "$SEARCH_ACTIVE" ]]; then
        title=" Search: \"$SEARCH_ACTIVE\" ($SESSION_COUNT results)"
    elif (( active_count > 0 )); then
        title=" Sessions ($visible_count)  ${FG_GREEN}▸ $active_count running"
    else
        title=" Sessions ($visible_count)"
    fi
    print_at_styled 1 2 "$LEFT_WIDTH" "${BOLD}${FG_CYAN}" "$title"
}

draw_right_header() {
    print_at_styled 1 $(( LEFT_WIDTH + 3 )) "$RIGHT_WIDTH" "${BOLD}${FG_CYAN}" " Detail"
}

draw_session_list() {
    # Uses the global DISPLAY_TYPES/DISPLAY_INDICES built by build_display_list()
    local visible_rows=$(( TERM_ROWS - 4 ))

    # Adjust scroll offset so SELECTED is visible
    if (( SELECTED < SCROLL_OFFSET )); then
        SCROLL_OFFSET=$SELECTED
    fi

    # Forward scroll: ensure selected item fits on screen
    local test_row=0
    local need_scroll=true
    while $need_scroll; do
        test_row=0
        for (( d=SCROLL_OFFSET; d<DISPLAY_COUNT; d++ )); do
            if [[ "${DISPLAY_TYPES[$d]}" == "group" ]]; then
                test_row=$(( test_row + 1 ))
            else
                test_row=$(( test_row + 2 ))
            fi
            if (( d == SELECTED )); then
                if (( test_row <= visible_rows )); then
                    need_scroll=false
                else
                    SCROLL_OFFSET=$(( SCROLL_OFFSET + 1 ))
                fi
                break
            fi
        done
        if (( SCROLL_OFFSET >= DISPLAY_COUNT )); then
            SCROLL_OFFSET=$(( DISPLAY_COUNT > 0 ? DISPLAY_COUNT - 1 : 0 ))
            break
        fi
    done

    # Render
    local row=2
    for (( d=SCROLL_OFFSET; d<DISPLAY_COUNT && row < TERM_ROWS - 1; d++ )); do
        if [[ "${DISPLAY_TYPES[$d]}" == "group" ]]; then
            local g="${DISPLAY_INDICES[$d]}"
            local gname="${GROUP_NAMES[$g]}"
            local gcount="${GROUP_COUNTS[$g]}"
            local fold_icon
            if is_group_folded "$gname"; then fold_icon="▶"; else fold_icon="▼"; fi
            local header
            if [[ "$gname" == "Bookmarks" ]]; then
                header=$(printf " %s ★ %s (%d)" "$fold_icon" "$gname" "$gcount")
            else
                header=$(printf " %s %s (%d)" "$fold_icon" "$gname" "$gcount")
            fi
            local gstyle="${BOLD}${FG_BLUE}"
            [[ "$gname" == "Archive" ]] && gstyle="${BOLD}${FG_GRAY}"
            if (( d == SELECTED )); then
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${REV}${gstyle}" "$header"
            else
                print_at_styled "$row" 2 "$LEFT_WIDTH" "$gstyle" "$header"
            fi
            row=$(( row + 1 ))
        else
            local i="${DISPLAY_INDICES[$d]}"
            local sid_short="${SESSION_IDS[$i]:0:8}"
            local elapsed="${SESSION_ELAPSED[$i]}"
            local branch="${SESSION_BRANCHES[$i]}"
            local model_short="${SESSION_MODEL_SHORT[$i]}"
            local ctx_short="${SESSION_CTX_SHORT[$i]}"
            local first_msg="${SESSION_FIRST_MSG[$i]}"

            # Status indicators
            local marks=""
            if [[ "$ATTACHED_SID" == "${SESSION_IDS[$i]}" ]]; then
                marks="${marks} ◀"
            elif is_session_working "${SESSION_IDS[$i]}"; then
                marks="${marks} ${SPINNER_CHARS[$SPINNER_IDX]}"
            elif is_session_done "${SESSION_IDS[$i]}"; then
                marks="${marks} ●"
            fi
            local ctx_val="${SESSION_CTX[$i]}"
            if (( ctx_val > CTX_WARN_THRESHOLD )); then
                marks="${marks} ⚠"
            fi
            if is_bookmarked "${SESSION_IDS[$i]}"; then
                marks="${marks} ★"
            fi
            if [[ -n "${SESSION_FORK_FROM[$i]}" ]]; then
                marks="${marks} ⑂${SESSION_FORK_FROM[$i]}"
            fi

            # Line 1: sid, elapsed, model, ctx, marks
            local meta="${model_short} ${ctx_short}"
            local line1
            if (( d == SELECTED )); then
                line1=$(printf " ▶ %-8s %-7s %s%s" "$sid_short" "$elapsed" "$meta" "$marks")
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${BOLD}${REV}${FG_WHITE}" "$line1"
            else
                if is_session_active "${SESSION_IDS[$i]}"; then
                    line1=$(printf "   %-8s %-7s %s%s" "$sid_short" "$elapsed" "$meta" "$marks")
                    print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_GREEN}" "$line1"
                else
                    line1=$(printf "   %-8s %-7s %s%s" "$sid_short" "$elapsed" "$meta" "$marks")
                    print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_WHITE}" "$line1"
                fi
            fi
            row=$(( row + 1 ))

            # Line 2: first message (session purpose)
            local line2="     ${first_msg}"
            if (( d == SELECTED )); then
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${REV}${FG_GRAY}" "$line2"
            else
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_GRAY}" "$line2"
            fi
            row=$(( row + 1 ))
        fi
    done

    while (( row < TERM_ROWS - 1 )); do
        print_at "$row" 2 "$LEFT_WIDTH" ""
        row=$(( row + 1 ))
    done
}

draw_detail_panel() {
    local col=$(( LEFT_WIDTH + 3 ))
    local width=$(( RIGHT_WIDTH - 2 ))
    local row=2

    local i
    i=$(selected_session_idx)
    if [[ -z "$i" ]] || (( SESSION_COUNT == 0 )); then
        print_at_styled "$row" "$col" "$width" "${FG_GRAY}" "  No session selected."
        row=$(( row + 1 ))
        while (( row < TERM_ROWS - 1 )); do
            print_at "$row" "$col" "$width" ""
            row=$(( row + 1 ))
        done
        return
    fi

    local sid="${SESSION_IDS[$i]}"
    local project="${SESSION_PROJECTS[$i]}"
    local branch="${SESSION_BRANCHES[$i]}"
    local cwd="${SESSION_CWDS[$i]}"
    local ts="${SESSION_TIMESTAMPS[$i]}"
    local first_msg="${SESSION_FIRST_MSG[$i]}"
    local model="${SESSION_MODELS[$i]}"
    local ctx="${SESSION_CTX[$i]}"

    # Lazy load detail for this session
    load_session_detail "$i"

    # ── Header ──
    print_at_styled "$row" "$col" "$width" "${BOLD}${FG_YELLOW}" "  Session"
    row=$(( row + 1 ))
    if [[ "$ATTACHED_SID" == "$sid" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_GREEN}◀ attached"
    elif is_session_working "$sid"; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_GREEN}${SPINNER_CHARS[$SPINNER_IDX]} working"
    elif is_session_done "$sid"; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_YELLOW}● done"
    else
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid"
    fi
    row=$(( row + 2 ))

    # ── Metadata ──
    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Project   ${RESET}${FG_WHITE}$project"
    row=$(( row + 1 ))
    if [[ -n "$branch" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Branch    ${RESET}${FG_GREEN}$branch"
        row=$(( row + 1 ))
    fi
    if [[ -n "$cwd" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  CWD       ${RESET}${FG_WHITE}$cwd"
        row=$(( row + 1 ))
    fi
    if [[ -n "$ts" ]]; then
        local formatted
        formatted=$(format_datetime "$ts")
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Started   ${RESET}${FG_WHITE}$formatted"
        row=$(( row + 1 ))
    fi
    row=$(( row + 1 ))

    # ── Fork info ──
    local fork_from="${SESSION_FORK_FROM[$i]}"
    if [[ -n "$fork_from" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Fork      ${RESET}${FG_YELLOW}⑂ from $fork_from"
        row=$(( row + 1 ))
    fi

    # ── Model & Context ──
    local model_display
    model_display=$(format_model_short "$model")
    local ctx_display
    ctx_display=$(format_tokens "$ctx")
    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Model     ${RESET}${FG_WHITE}$model_display"
    row=$(( row + 1 ))
    if (( ctx > CTX_WARN_THRESHOLD )); then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Context   ${RESET}${FG_YELLOW}${ctx_display} tokens ⚠"
        row=$(( row + 1 ))
        print_at_styled "$row" "$col" "$width" "${FG_YELLOW}" "            Run /compact in session or press f to fork"
        row=$(( row + 1 ))
    else
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Context   ${RESET}${FG_WHITE}${ctx_display} tokens"
        row=$(( row + 1 ))
    fi

    # ── Detail (lazy loaded) ──
    if [[ -n "$DETAIL_MSG_COUNT" ]]; then
        local output_display
        output_display=$(format_tokens "$DETAIL_TOTAL_OUTPUT")
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Messages  ${RESET}${FG_WHITE}$DETAIL_MSG_COUNT turns"
        row=$(( row + 1 ))
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Output    ${RESET}${FG_WHITE}${output_display} tokens"
        row=$(( row + 1 ))
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Tools     ${RESET}${FG_WHITE}$DETAIL_TOOL_COUNT calls ($DETAIL_TOP_TOOL)"
        row=$(( row + 1 ))
        if [[ -n "$DETAIL_VERSION" && "$DETAIL_VERSION" != "null" ]]; then
            print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Version   ${RESET}${FG_WHITE}$DETAIL_VERSION"
            row=$(( row + 1 ))
        fi
    fi
    row=$(( row + 1 ))

    # ── First Message ──
    local line_width=$(( width - 4 ))
    print_at_styled "$row" "$col" "$width" "${BOLD}${FG_MAGENTA}" "  ── First Message ──"
    row=$(( row + 1 ))
    local remaining="$first_msg"
    while [[ -n "$remaining" ]] && (( row < TERM_ROWS - 8 )); do
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  ${remaining:0:$line_width}"
        remaining="${remaining:$line_width}"
        row=$(( row + 1 ))
    done
    row=$(( row + 1 ))

    # ── Last Message ──
    if [[ -n "$DETAIL_LAST_MSG" && "$DETAIL_LAST_MSG" != "$first_msg" ]]; then
        print_at_styled "$row" "$col" "$width" "${BOLD}${FG_MAGENTA}" "  ── Last Message ──"
        row=$(( row + 1 ))
        remaining="$DETAIL_LAST_MSG"
        while [[ -n "$remaining" ]] && (( row < TERM_ROWS - 3 )); do
            print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  ${remaining:0:$line_width}"
            remaining="${remaining:$line_width}"
            row=$(( row + 1 ))
        done
    fi

    while (( row < TERM_ROWS - 1 )); do
        print_at "$row" "$col" "$width" ""
        row=$(( row + 1 ))
    done
}

draw_status_bar() {
    local bar_row=$TERM_ROWS
    move_to "$bar_row" 1
    if $COMMAND_MODE; then
        printf "${REV}${FG_WHITE} :${COMMAND_INPUT}█%-$(( TERM_COLS - ${#COMMAND_INPUT} - 3 ))s${RESET}" " Enter: Run  Esc: Cancel"
    elif $SEARCH_MODE; then
        printf "${REV}${FG_WHITE} /${SEARCH_QUERY}█%-$(( TERM_COLS - ${#SEARCH_QUERY} - 3 ))s${RESET}" " Enter: Search  Esc: Cancel"
