draw_session_list() {
    # Build a flat display list: each entry is either a group header or a session.
    # display_types[n] = "group" | "session"
    # display_indices[n] = group index (for group) or session index (for session)
    local -a display_types=()
    local -a display_indices=()

    if [[ -n "$SEARCH_ACTIVE" ]] || (( GROUP_COUNT == 0 )); then
        # In search mode or no groups: flat list, no headers
        for (( i=0; i<SESSION_COUNT; i++ )); do
            display_types+=("session")
            display_indices+=("$i")
        done
    else
        for (( g=0; g<GROUP_COUNT; g++ )); do
            display_types+=("group")
            display_indices+=("$g")
            local gstart="${GROUP_STARTS[$g]}"
            local gcount="${GROUP_COUNTS[$g]}"
            for (( s=0; s<gcount; s++ )); do
                display_types+=("session")
                display_indices+=("$(( gstart + s ))")
            done
        done
    fi

    local display_total=${#display_types[@]}

    # Map SELECTED (session index) to display index for scroll calculation
    local selected_display=0
    for (( d=0; d<display_total; d++ )); do
        if [[ "${display_types[$d]}" == "session" && "${display_indices[$d]}" -eq "$SELECTED" ]]; then
            selected_display=$d
            break
        fi
    done

    # Scroll: each item takes 1 line (group header) or 2 lines (session)
    # Calculate total row heights for scroll
    local visible_rows=$(( TERM_ROWS - 4 ))

    # Adjust scroll offset (in display indices) so selected is visible
    if (( selected_display < SCROLL_OFFSET )); then
        SCROLL_OFFSET=$selected_display
        # Include group header above if the selected is first in its group
        if (( SCROLL_OFFSET > 0 )) && [[ "${display_types[$((SCROLL_OFFSET-1))]}" == "group" ]]; then
            SCROLL_OFFSET=$(( SCROLL_OFFSET - 1 ))
        fi
    fi

    # Forward scroll: render from SCROLL_OFFSET until selected is visible
    local test_row=0
    local need_scroll=true
    while $need_scroll; do
        test_row=0
        for (( d=SCROLL_OFFSET; d<display_total; d++ )); do
            if [[ "${display_types[$d]}" == "group" ]]; then
                test_row=$(( test_row + 1 ))
            else
                test_row=$(( test_row + 2 ))
            fi
            if (( d == selected_display )); then
                if (( test_row <= visible_rows )); then
                    need_scroll=false
                else
                    SCROLL_OFFSET=$(( SCROLL_OFFSET + 1 ))
                fi
                break
            fi
        done
        # Safety: if we've scrolled past everything
        if (( SCROLL_OFFSET >= display_total )); then
            SCROLL_OFFSET=$(( display_total > 0 ? display_total - 1 : 0 ))
            break
        fi
    done

    # Render
    local row=2
    for (( d=SCROLL_OFFSET; d<display_total && row < TERM_ROWS - 1; d++ )); do
        if [[ "${display_types[$d]}" == "group" ]]; then
            local g="${display_indices[$d]}"
            local gname="${GROUP_NAMES[$g]}"
            local gcount="${GROUP_COUNTS[$g]}"
            local header
            header=$(printf " ┈ %s (%d)" "$gname" "$gcount")
            print_at_styled "$row" 2 "$LEFT_WIDTH" "${BOLD}${FG_BLUE}" "$header"
            row=$(( row + 1 ))
        else
            local i="${display_indices[$d]}"
            local sid_short="${SESSION_IDS[$i]:0:8}"
            local elapsed="${SESSION_ELAPSED[$i]}"
            local branch="${SESSION_BRANCHES[$i]}"
            local model_short="${SESSION_MODEL_SHORT[$i]}"
            local ctx_short="${SESSION_CTX_SHORT[$i]}"
            local first_msg="${SESSION_FIRST_MSG[$i]}"

            # Status indicators
            local marks=""
            if [[ "$ATTACHED_SID" == "${SESSION_IDS[$i]}" ]]; then
                marks="${marks} ◀"
            elif is_session_needs_attention "${SESSION_IDS[$i]}"; then
                marks="${marks} 🔔"
            elif is_session_active "${SESSION_IDS[$i]}"; then
                marks="${marks} ▸"
            fi
            local ctx_val="${SESSION_CTX[$i]}"
            if (( ctx_val > CTX_WARN_THRESHOLD )); then
                marks="${marks} ⚠"
            fi
            if [[ -n "${SESSION_FORK_FROM[$i]}" ]]; then
                marks="${marks} ⑂${SESSION_FORK_FROM[$i]}"
            fi

            # Line 1: sid, elapsed, model, ctx, marks
            local meta="${model_short} ${ctx_short}"
            local line1
            if (( i == SELECTED )); then
                line1=$(printf " ▶ %-8s %-7s %s%s" "$sid_short" "$elapsed" "$meta" "$marks")
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${BOLD}${REV}${FG_WHITE}" "$line1"
            else
                if [[ "$marks" == *"▸"* ]]; then
                    line1=$(printf "   %-8s %-7s %s%s" "$sid_short" "$elapsed" "$meta" "$marks")
                    print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_GREEN}" "$line1"
                else
                    line1=$(printf "   %-8s %-7s %s%s" "$sid_short" "$elapsed" "$meta" "$marks")
                    print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_WHITE}" "$line1"
                fi
            fi
            row=$(( row + 1 ))

            # Line 2: first message (session purpose)
            local line2="     ${first_msg}"
            if (( i == SELECTED )); then
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${REV}${FG_GRAY}" "$line2"
            else
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_GRAY}" "$line2"
            fi
            row=$(( row + 1 ))
        fi
    done

    while (( row < TERM_ROWS - 1 )); do
        print_at "$row" 2 "$LEFT_WIDTH" ""
        row=$(( row + 1 ))
    done
}

draw_detail_panel() {
    local col=$(( LEFT_WIDTH + 3 ))
    local width=$(( RIGHT_WIDTH - 2 ))
    local row=2

    if (( SESSION_COUNT == 0 )); then
        print_at_styled "$row" "$col" "$width" "${FG_GRAY}" "  No sessions found."
        row=$(( row + 1 ))
        while (( row < TERM_ROWS - 1 )); do
            print_at "$row" "$col" "$width" ""
            row=$(( row + 1 ))
        done
        return
    fi

    local i=$SELECTED
    local sid="${SESSION_IDS[$i]}"
    local project="${SESSION_PROJECTS[$i]}"
    local branch="${SESSION_BRANCHES[$i]}"
    local cwd="${SESSION_CWDS[$i]}"
    local ts="${SESSION_TIMESTAMPS[$i]}"
    local first_msg="${SESSION_FIRST_MSG[$i]}"
    local model="${SESSION_MODELS[$i]}"
    local ctx="${SESSION_CTX[$i]}"

    # Lazy load detail for this session
    load_session_detail "$i"

    # ── Header ──
    print_at_styled "$row" "$col" "$width" "${BOLD}${FG_YELLOW}" "  Session"
    row=$(( row + 1 ))
    if [[ "$ATTACHED_SID" == "$sid" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_GREEN}◀ attached"
    elif is_session_needs_attention "$sid"; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_YELLOW}🔔 needs input"
    elif is_session_active "$sid"; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_GREEN}▸ running"
    else
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid"
    fi
    row=$(( row + 2 ))

    # ── Metadata ──
    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Project   ${RESET}${FG_WHITE}$project"
    row=$(( row + 1 ))
    if [[ -n "$branch" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Branch    ${RESET}${FG_GREEN}$branch"
        row=$(( row + 1 ))
    fi
    if [[ -n "$cwd" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  CWD       ${RESET}${FG_WHITE}$cwd"
        row=$(( row + 1 ))
    fi
    if [[ -n "$ts" ]]; then
        local formatted
        formatted=$(format_datetime "$ts")
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Started   ${RESET}${FG_WHITE}$formatted"
        row=$(( row + 1 ))
    fi
    row=$(( row + 1 ))

    # ── Fork info ──
    local fork_from="${SESSION_FORK_FROM[$i]}"
    if [[ -n "$fork_from" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Fork      ${RESET}${FG_YELLOW}⑂ from $fork_from"
        row=$(( row + 1 ))
    fi

    # ── Model & Context ──
    local model_display
    model_display=$(format_model_short "$model")
    local ctx_display
    ctx_display=$(format_tokens "$ctx")
    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Model     ${RESET}${FG_WHITE}$model_display"
    row=$(( row + 1 ))
    if (( ctx > CTX_WARN_THRESHOLD )); then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Context   ${RESET}${FG_YELLOW}${ctx_display} tokens ⚠"
        row=$(( row + 1 ))
        print_at_styled "$row" "$col" "$width" "${FG_YELLOW}" "            Run /compact in session or press f to fork"
        row=$(( row + 1 ))
    else
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Context   ${RESET}${FG_WHITE}${ctx_display} tokens"
        row=$(( row + 1 ))
    fi

    # ── Detail (lazy loaded) ──
    if [[ -n "$DETAIL_MSG_COUNT" ]]; then
        local output_display
        output_display=$(format_tokens "$DETAIL_TOTAL_OUTPUT")
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Messages  ${RESET}${FG_WHITE}$DETAIL_MSG_COUNT turns"
        row=$(( row + 1 ))
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Output    ${RESET}${FG_WHITE}${output_display} tokens"
        row=$(( row + 1 ))
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Tools     ${RESET}${FG_WHITE}$DETAIL_TOOL_COUNT calls ($DETAIL_TOP_TOOL)"
        row=$(( row + 1 ))
        if [[ -n "$DETAIL_VERSION" && "$DETAIL_VERSION" != "null" ]]; then
            print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Version   ${RESET}${FG_WHITE}$DETAIL_VERSION"
            row=$(( row + 1 ))
        fi
    fi
    row=$(( row + 1 ))

    # ── First Message ──
    local line_width=$(( width - 4 ))
    print_at_styled "$row" "$col" "$width" "${BOLD}${FG_MAGENTA}" "  ── First Message ──"
    row=$(( row + 1 ))
    local remaining="$first_msg"
    while [[ -n "$remaining" ]] && (( row < TERM_ROWS - 8 )); do
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  ${remaining:0:$line_width}"
        remaining="${remaining:$line_width}"
        row=$(( row + 1 ))
    done
    row=$(( row + 1 ))

    # ── Last Message ──
    if [[ -n "$DETAIL_LAST_MSG" && "$DETAIL_LAST_MSG" != "$first_msg" ]]; then
        print_at_styled "$row" "$col" "$width" "${BOLD}${FG_MAGENTA}" "  ── Last Message ──"
        row=$(( row + 1 ))
        remaining="$DETAIL_LAST_MSG"
        while [[ -n "$remaining" ]] && (( row < TERM_ROWS - 3 )); do
            print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  ${remaining:0:$line_width}"
            remaining="${remaining:$line_width}"
            row=$(( row + 1 ))
        done
    fi

    while (( row < TERM_ROWS - 1 )); do
        print_at "$row" "$col" "$width" ""
        row=$(( row + 1 ))
    done
}

draw_status_bar() {
    local bar_row=$TERM_ROWS
    move_to "$bar_row" 1
    if $COMMAND_MODE; then
        printf "${REV}${FG_WHITE} :${COMMAND_INPUT}█%-$(( TERM_COLS - ${#COMMAND_INPUT} - 3 ))s${RESET}" " Enter: Run  Esc: Cancel"
    elif $SEARCH_MODE; then
        printf "${REV}${FG_WHITE} /${SEARCH_QUERY}█%-$(( TERM_COLS - ${#SEARCH_QUERY} - 3 ))s${RESET}" " Enter: Search  Esc: Cancel"
    elif [[ -n "$STATUS_MSG" ]] && (( ${EPOCHSECONDS:-$(date +%s)} < STATUS_MSG_EXPIRE )); then
        if [[ "$STATUS_MSG" == Error:* ]]; then
            printf "${BG_DARK}${FG_YELLOW}%-${TERM_COLS}s${RESET}" " $STATUS_MSG"
        else
            printf "${BG_DARK}${FG_GREEN}%-${TERM_COLS}s${RESET}" " $STATUS_MSG"
        fi
    elif [[ -n "$SEARCH_ACTIVE" ]]; then
        local bar_text=" ↑↓ Navigate  Enter: Open  Esc: Clear search  /: New search  r: Refresh"
        printf "${BG_DARK}${FG_WHITE}%-${TERM_COLS}s${RESET}" "$bar_text"
    else
        local bar_text=" j/k Nav  Enter: Attach  ^b0: List  ^bTab: Toggle  Esc: Detach  f: Fork  /: Search  q: Quit"
        printf "${BG_DARK}${FG_WHITE}%-${TERM_COLS}s${RESET}" "$bar_text"
    fi
}

draw_loading() {
    clear_screen
    local mid_row=$(( TERM_ROWS / 2 ))
    local mid_col=$(( TERM_COLS / 2 - 12 ))
    move_to "$mid_row" "$mid_col"
    printf "${BOLD}${FG_CYAN}ssread${RESET}${FG_GRAY} loading sessions...${RESET}"
}

PREV_RIGHT_WIDTH=-1

render() {
    get_dimensions
    refresh_active_windows
    # Compact mode: hide detail panel when pane is narrow
    if (( TERM_COLS < 80 )); then
        LEFT_WIDTH=$(( TERM_COLS - 2 ))
        RIGHT_WIDTH=0
    fi
    # Clear screen on layout mode change to avoid ghost text
    if (( RIGHT_WIDTH != PREV_RIGHT_WIDTH )); then
        clear_screen
        CACHED_BORDER_ROWS=0  # force border redraw
        PREV_RIGHT_WIDTH=$RIGHT_WIDTH
    fi
    # When split, update detail file for the watcher pane
    if [[ -n "$ATTACHED_SID" ]] && pane_has_split; then
        write_detail_file
    fi
    local buf
    buf=$(
        draw_border
        draw_left_header
        if (( RIGHT_WIDTH > 0 )); then
            draw_right_header
        fi
        draw_session_list
        if (( RIGHT_WIDTH > 0 )); then
            draw_detail_panel
        fi
        draw_status_bar
    )
    printf "%s" "$buf"
}

# ── Input Handling ─────────────────────────────────────────────────────────
_KEY=""

read_key() {
    _KEY=""
    local c="" _read_rc=0
    # Timeout after 2s so we periodically re-render (catches pane resizes, activity updates)
    IFS= read -rsn1 -t 2 c || _read_rc=$?
    if (( _read_rc > 0 )) && [[ -z "$c" ]]; then
        # Timeout or signal — return empty key to trigger re-render
        return
    fi
    if [[ "$c" == $'\x1b' ]]; then
        local seq=""
        IFS= read -rsn1 -t 1 seq || true
        if [[ "$seq" == "[" ]]; then
            local code=""
            IFS= read -rsn1 -t 1 code || true
            _KEY="ESC[${code}"
        else
            _KEY="ESC"
        fi
    elif [[ "$c" == $'\t' ]]; then
        _KEY="TAB"
    elif [[ "$c" == "" ]]; then
        _KEY="ENTER"
    else
        _KEY="$c"
    fi
}

handle_search_input() {
    case "$_KEY" in
        ENTER)
            SEARCH_MODE=false
            if [[ -n "$SEARCH_QUERY" ]]; then
                SEARCH_ACTIVE="$SEARCH_QUERY"
                SELECTED=0
                SCROLL_OFFSET=0
                draw_loading
                load_sessions
                search_sessions "$SEARCH_ACTIVE"
                group_sessions
            fi
            ;;
        ESC)
            SEARCH_MODE=false
            if [[ -n "$SEARCH_ACTIVE" ]]; then
                # Clear search and reload all sessions
                SEARCH_QUERY=""
                SEARCH_ACTIVE=""
                SELECTED=0
                SCROLL_OFFSET=0
                load_sessions
                group_sessions
            fi
            SEARCH_QUERY=""
            ;;
        $'\x7f'|$'\b')
            SEARCH_QUERY="${SEARCH_QUERY%?}"
            ;;
        *)
            if [[ ${#_KEY} -eq 1 ]] && [[ "$_KEY" =~ [[:print:]] ]]; then
                SEARCH_QUERY="${SEARCH_QUERY}${_KEY}"
            fi
            ;;
    esac
}

handle_command_input() {
    case "$_KEY" in
        ENTER)
            COMMAND_MODE=false
            if [[ -n "$COMMAND_INPUT" ]]; then
                execute_command "$COMMAND_INPUT"
            fi
            COMMAND_INPUT=""
            ;;
        ESC)
            COMMAND_MODE=false
            COMMAND_INPUT=""
            ;;
        $'\x7f'|$'\b')
            COMMAND_INPUT="${COMMAND_INPUT%?}"
            ;;
        *)
            if [[ ${#_KEY} -eq 1 ]] && [[ "$_KEY" =~ [[:print:]] ]]; then
                COMMAND_INPUT="${COMMAND_INPUT}${_KEY}"
            fi
            ;;
    esac
}

handle_input() {
    read_key

    if $COMMAND_MODE; then
        handle_command_input
        return
    fi

    if $SEARCH_MODE; then
        handle_search_input
        return
    fi

    case "$_KEY" in
        "ESC[A"|k)
            if (( SELECTED > 0 )); then
                SELECTED=$(( SELECTED - 1 ))
            fi
            ;;
        "ESC[B"|j)
            if (( SELECTED < SESSION_COUNT - 1 )); then
                SELECTED=$(( SELECTED + 1 ))
            fi
            ;;
        ENTER)
            if (( SESSION_COUNT > 0 )); then
                local sid="${SESSION_IDS[$SELECTED]}"
                local cwd="${SESSION_CWDS[$SELECTED]}"
                if [[ -n "${TMUX:-}" ]]; then
                    pane_attach_session "$sid" "$cwd"
                else
                    launch_session_direct "$sid" "$cwd"
                fi
            fi
            ;;
        TAB)
            if [[ -n "${TMUX:-}" ]] && pane_has_split; then
                # Toggle focus to session pane (pane 2 in 3-pane layout)
                tmux select-pane -t "$TMUX_SESSION_NAME:list.2" 2>/dev/null || true
            fi
            ;;
        f)
            if (( SESSION_COUNT > 0 )); then
                fork_session "$SELECTED"
            fi
            ;;
        q)
            exit 0
            ;;
        Q)
            # Kill all claude windows then quit
            tmux_kill_all_sessions
            exit 0
            ;;
        /)
            SEARCH_MODE=true
            SEARCH_QUERY=""
            ;;
        :)
            COMMAND_MODE=true
            COMMAND_INPUT=""
            ;;
        ESC)
            if [[ -n "$SEARCH_ACTIVE" ]]; then
                SEARCH_QUERY=""
                SEARCH_ACTIVE=""
                SELECTED=0
                SCROLL_OFFSET=0
                load_sessions
                group_sessions
            elif [[ -n "$ATTACHED_SID" ]]; then
                pane_detach_current
            fi
            ;;
        r)
            SELECTED=0
            SCROLL_OFFSET=0
            ACTIVE_WINDOWS_LAST_REFRESH=0
            draw_loading
            load_sessions
            group_sessions
            ;;
        g)
            SELECTED=0
            SCROLL_OFFSET=0
            ;;
        G)
            if (( SESSION_COUNT > 0 )); then
                SELECTED=$(( SESSION_COUNT - 1 ))
            fi
            ;;
    esac
}

# ── Self-Test ──────────────────────────────────────────────────────────────
run_tests() {
    local ssread_dir
    ssread_dir="$(cd "$(dirname "$0")" && pwd)"
    local test_file="$ssread_dir/tests/test_ssread.sh"

    if [[ ! -f "$test_file" ]]; then
        echo "Error: test file not found at $test_file"
        exit 1
    fi

    if ! command -v bats &>/dev/null; then
        echo "Error: bats is required to run tests."
        echo "  brew install bats-core  (macOS)"
        echo "  apt install bats        (Ubuntu/Debian)"
        exit 1
    fi

    exec bats "$test_file"
}

# ── Main ───────────────────────────────────────────────────────────────────
main() {
    # Handle --test before anything else
    if [[ "${1:-}" == "--test" ]]; then
        run_tests
    fi

    check_dependencies

    if [[ ! -d "$CLAUDE_PROJECTS_DIR" ]]; then
        echo "Error: $CLAUDE_PROJECTS_DIR not found."
        echo "No Claude Code session data available."
        exit 1
    fi

    # Bootstrap into tmux if not already inside
    ensure_tmux_session "$@"

    get_tmux_session_name
    setup_terminal
    get_dimensions
    draw_loading
    load_sessions
    group_sessions
    clear_screen

    while true; do
        render
        handle_input
    done
}

main "$@"
