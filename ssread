#!/usr/bin/env bash
# ssread — Claude Code session manager TUI
# Browse sessions from ~/.claude/projects/ and launch them in tmux windows
# Each session runs in its own tmux window for parallel task management

set -euo pipefail

# ── Configuration ──────────────────────────────────────────────────────────
CLAUDE_PROJECTS_DIR="$HOME/.claude/projects"
SSREAD_TMUX_SESSION="ssread"
SSREAD_INSIDE_TMUX="${SSREAD_INSIDE_TMUX:-}"

# ── Color & Style ──────────────────────────────────────────────────────────
# Use $'...' so variables hold real ESC bytes, not literal \033 strings.
# This ensures colors work both in printf format strings AND in %s arguments.
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'
REV=$'\033[7m'
FG_CYAN=$'\033[36m'
FG_YELLOW=$'\033[33m'
FG_GREEN=$'\033[32m'
FG_WHITE=$'\033[37m'
FG_GRAY=$'\033[90m'
FG_BLUE=$'\033[34m'
FG_MAGENTA=$'\033[35m'
BG_DARK=$'\033[48;5;235m'

# ── Dependency Check ───────────────────────────────────────────────────────
check_dependencies() {
    local missing=()
    command -v jq &>/dev/null || missing+=("jq")
    command -v tmux &>/dev/null || missing+=("tmux")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Error: missing dependencies: ${missing[*]}"
        echo "  brew install ${missing[*]}  (macOS)"
        echo "  apt install ${missing[*]}   (Ubuntu/Debian)"
        exit 1
    fi
}

# ── tmux Bootstrap ─────────────────────────────────────────────────────────
# If not inside our tmux session, create/attach to one and re-exec ssread inside it.
ensure_tmux_session() {
    # Already inside our tmux session — nothing to do
    if [[ -n "$SSREAD_INSIDE_TMUX" ]]; then
        return
    fi

    # Already in tmux but not our session — create a new session grouped or standalone
    if [[ -n "${TMUX:-}" ]]; then
        # We're in some other tmux session. Warn and launch inside current tmux.
        SSREAD_INSIDE_TMUX=1
        return
    fi

    # Not in tmux at all — create or attach to ssread session
    if tmux has-session -t "$SSREAD_TMUX_SESSION" 2>/dev/null; then
        # Session exists — attach to it (ssread TUI should be in window 0)
        exec tmux attach-session -t "$SSREAD_TMUX_SESSION"
    else
        # Create new session with ssread TUI in window 0
        exec tmux new-session -s "$SSREAD_TMUX_SESSION" -n "list" \
            "SSREAD_INSIDE_TMUX=1 $(printf '%q' "$0") $(printf '%q ' "$@")"
    fi
}

# ── tmux Window Management ────────────────────────────────────────────────
TMUX_SESSION_NAME=""
ATTACHED_SID=""  # session ID currently shown in right pane (empty = no split)

# Get the tmux session name we're running in
get_tmux_session_name() {
    if [[ -n "${TMUX:-}" ]]; then
        TMUX_SESSION_NAME=$(tmux display-message -p '#S' 2>/dev/null || echo "")
    else
        TMUX_SESSION_NAME=""
    fi
}

# Check if a claude session is already running in a tmux window.
# Returns the window index if found, empty string if not.
tmux_find_session_window() {
    local sid="$1"
    local sid_short="${sid:0:8}"

    if [[ -z "${TMUX:-}" ]]; then
        echo ""
        return
    fi

    # Search window names for our session ID prefix
    tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_index} #{window_name}' 2>/dev/null \
        | while IFS=' ' read -r idx name; do
            if [[ "$name" == "s:$sid_short" ]]; then
                echo "$idx"
                return
            fi
        done
}

# Kill all claude windows (not the list window)
tmux_kill_all_sessions() {
    if [[ -z "${TMUX:-}" ]]; then
        return
    fi

    tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_index} #{window_name}' 2>/dev/null \
        | while IFS=' ' read -r idx name; do
            if [[ "$name" == s:* ]]; then
                tmux kill-window -t "$TMUX_SESSION_NAME:$idx" 2>/dev/null || true
            fi
        done
}

# Count active claude windows
tmux_active_count() {
    if [[ -z "${TMUX:-}" ]]; then
        echo 0
        return
    fi

    local count
    count=$(tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name}' 2>/dev/null \
        | grep -cv '^list$' 2>/dev/null) || count=0
    echo "$count"
}

# ── Split-Pane Management ────────────────────────────────────────────────
# Layout: pane 0 (ssread, left) | pane 1 (detail watcher, top-right)
#                                | pane 2 (session, bottom-right)
# Sessions run in hidden tmux windows (named "s:XXXXXXXX").
# break-pane/join-pane swaps sessions without killing processes.

DETAIL_FILE="/tmp/ssread_detail_$$"

# Check if session pane is attached (more than 1 pane in list window)
pane_has_split() {
    local count
    count=$(tmux list-panes -t "$TMUX_SESSION_NAME:list" 2>/dev/null | wc -l | tr -d ' ')
    (( count > 1 ))
}

# Write detail info to temp file for the detail watcher pane
write_detail_file() {
    if (( SESSION_COUNT == 0 )); then
        printf '' > "$DETAIL_FILE"
        return
    fi

    local i=$SELECTED
    local sid="${SESSION_IDS[$i]}"
    local project="${SESSION_PROJECTS[$i]}"
    local branch="${SESSION_BRANCHES[$i]}"
    local cwd="${SESSION_CWDS[$i]}"
    local model_short="${SESSION_MODEL_SHORT[$i]}"
    local ctx_short="${SESSION_CTX_SHORT[$i]}"
    local first_msg="${SESSION_FIRST_MSG[$i]}"

    load_session_detail "$i"

    {
        printf "${BOLD}${FG_YELLOW} Session${RESET}\n"
        if [[ "$ATTACHED_SID" == "$sid" ]]; then
            printf " %s  ${FG_GREEN}◀ attached${RESET}\n" "$sid"
        elif is_session_needs_attention "$sid"; then
            printf " %s  ${FG_YELLOW}🔔 needs input${RESET}\n" "$sid"
        elif is_session_active "$sid"; then
            printf " %s  ${FG_GREEN}▸ running${RESET}\n" "$sid"
        else
            printf " %s\n" "$sid"
        fi
        printf "\n"
        printf " ${FG_CYAN}Project ${RESET}%s\n" "$project"
        [[ -n "$branch" ]] && printf " ${FG_CYAN}Branch  ${RESET}${FG_GREEN}%s${RESET}\n" "$branch"
        [[ -n "$cwd" ]] && printf " ${FG_CYAN}CWD     ${RESET}%s\n" "$cwd"
        printf " ${FG_CYAN}Model   ${RESET}%s  %s\n" "$model_short" "$ctx_short"
        if [[ -n "$DETAIL_MSG_COUNT" ]]; then
            local out_display
            out_display=$(format_tokens "$DETAIL_TOTAL_OUTPUT")
            printf " ${FG_CYAN}Msgs    ${RESET}%s turns  %s output\n" "$DETAIL_MSG_COUNT" "$out_display"
            printf " ${FG_CYAN}Tools   ${RESET}%s calls (%s)\n" "$DETAIL_TOOL_COUNT" "$DETAIL_TOP_TOOL"
        fi
        printf "\n${BOLD}${FG_MAGENTA} ── First Message ──${RESET}\n"
        printf " %s\n" "$first_msg"
        if [[ -n "$DETAIL_LAST_MSG" && "$DETAIL_LAST_MSG" != "$first_msg" ]]; then
            printf "\n${BOLD}${FG_MAGENTA} ── Last Message ──${RESET}\n"
            printf " %s\n" "$DETAIL_LAST_MSG"
        fi
    } > "$DETAIL_FILE"
}

# Ensure a hidden tmux window exists for the given session
_ensure_session_window() {
    local sid="$1" cwd="$2"
    local sid_short="${sid:0:8}"

    if tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name}' 2>/dev/null \
        | grep -qF "s:$sid_short"; then
        return
    fi

    local cd_cmd=""
    if [[ -n "$cwd" && -d "$cwd" ]]; then
        cd_cmd="cd $(printf '%q' "$cwd") && "
    fi
    tmux new-window -d -t "$TMUX_SESSION_NAME" -n "s:$sid_short" \
        "${cd_cmd}claude --resume '$sid'; echo ''; echo 'Session ended. Press any key to close.'; read -rsn1"
    tmux set-option -t "$TMUX_SESSION_NAME:s:$sid_short" monitor-silence 15 2>/dev/null || true
}

# Create the 3-pane layout and join a session window into it
_create_split_layout() {
    local session_win="$1"  # e.g. "s:aaaa1111"

    # Write initial detail content
    write_detail_file

    # Step 1: split ssread (pane 0) horizontally → pane 0 (left) + pane 1 (detail watcher, right)
    local watcher_cmd="f='${DETAIL_FILE}'; prev=''; tput civis 2>/dev/null; while true; do cur=\$(cat \"\$f\" 2>/dev/null || true); if [ \"\$cur\" != \"\$prev\" ]; then printf '\\033[H\\033[2J%s' \"\$cur\"; prev=\"\$cur\"; fi; sleep 0.3; done"
    tmux split-window -h -d -t "$TMUX_SESSION_NAME:list.0" -l 55% "$watcher_cmd" 2>/dev/null || true

    # Step 2: join session into bottom-right (split pane 1 vertically)
    tmux join-pane -v -s "$TMUX_SESSION_NAME:$session_win" -t "$TMUX_SESSION_NAME:list.1" -l 70% 2>/dev/null || true

    # Brief wait for tmux to settle pty dimensions
    sleep 0.05
    CACHED_BORDER_ROWS=0
    PREV_RIGHT_WIDTH=-1

    # Focus session pane (pane 2)
    tmux select-pane -t "$TMUX_SESSION_NAME:list.2" 2>/dev/null || true
}

# Detach current session: break session pane to hidden window, kill detail watcher
pane_detach_current() {
    if [[ -z "$ATTACHED_SID" ]] || ! pane_has_split; then
        ATTACHED_SID=""
        return
    fi
    local sid_short="${ATTACHED_SID:0:8}"

    # Break session pane (pane 2) back to hidden window
    if tmux list-panes -t "$TMUX_SESSION_NAME:list" -F '#{pane_index}' 2>/dev/null | grep -q '^2$'; then
        tmux break-pane -d -s "$TMUX_SESSION_NAME:list.2" -n "s:$sid_short" 2>/dev/null || true
    fi

    # Kill detail watcher pane (pane 1)
    if tmux list-panes -t "$TMUX_SESSION_NAME:list" -F '#{pane_index}' 2>/dev/null | grep -q '^1$'; then
        tmux kill-pane -t "$TMUX_SESSION_NAME:list.1" 2>/dev/null || true
    fi

    ATTACHED_SID=""
    sleep 0.05
    CACHED_BORDER_ROWS=0
    PREV_RIGHT_WIDTH=-1
}

# Launch (if needed) and attach a session to the right pane
pane_attach_session() {
    local sid="$1"
    local cwd="$2"
    local sid_short="${sid:0:8}"

    # Already showing this session — just refocus
    if [[ "$ATTACHED_SID" == "$sid" ]] && pane_has_split; then
        tmux select-pane -t "$TMUX_SESSION_NAME:list.2" 2>/dev/null || true
        return
    fi

    # Detach whatever is currently attached
    pane_detach_current

    # Ensure hidden window exists
    _ensure_session_window "$sid" "$cwd"

    # Create 3-pane layout with this session
    _create_split_layout "s:$sid_short"
    ATTACHED_SID="$sid"
}

# ── Terminal Setup ─────────────────────────────────────────────────────────
TERM_ROWS=0
TERM_COLS=0
LEFT_WIDTH=0
RIGHT_WIDTH=0
ORIG_STTY=""

setup_terminal() {
    ORIG_STTY=$(stty -g 2>/dev/null || true)
    tput smcup        # alternate screen buffer
    tput civis        # hide cursor
    stty -echo -icanon min 1 time 0
    setup_tmux_keybindings
    trap cleanup EXIT INT TERM
}

# Set up tmux key bindings for pane navigation within ssread session.
# Ctrl+b 0 → focus pane 0 (list),  Ctrl+b Tab → toggle between panes
setup_tmux_keybindings() {
    if [[ -z "${TMUX:-}" || -z "$TMUX_SESSION_NAME" ]]; then
        return
    fi
    # Save original bindings for later restoration
    ORIG_BIND_0=$(tmux list-keys 2>/dev/null | grep "^bind-key.*\"0\"" | head -1) || true
    ORIG_BIND_TAB=$(tmux list-keys 2>/dev/null | grep "^bind-key.*\"Tab\"" | head -1) || true
    # Bind "0" to select list pane (normally selects window 0)
    tmux bind-key 0 select-pane -t "$TMUX_SESSION_NAME:list.0" 2>/dev/null || true
    # Bind Tab to toggle between panes (normally last-window)
    tmux bind-key Tab last-pane 2>/dev/null || true
}

# Restore default tmux key bindings
restore_tmux_keybindings() {
    if [[ -z "${TMUX:-}" ]]; then
        return
    fi
    tmux bind-key 0 select-window -t :0 2>/dev/null || true
    tmux bind-key Tab last-window 2>/dev/null || true
}

cleanup() {
    restore_tmux_keybindings
    rm -f "$DETAIL_FILE" 2>/dev/null || true
    tput rmcup        # restore screen
    tput cnorm        # show cursor
    if [[ -n "$ORIG_STTY" ]]; then
        stty "$ORIG_STTY" 2>/dev/null || true
    else
        stty echo icanon 2>/dev/null || true
    fi
}

get_dimensions() {
    local size
    size=$(stty size 2>/dev/null) || size="$(tput lines) $(tput cols)"
    TERM_ROWS="${size%% *}"
    TERM_COLS="${size##* }"
    LEFT_WIDTH=$(( TERM_COLS * 45 / 100 ))
    RIGHT_WIDTH=$(( TERM_COLS - LEFT_WIDTH - 1 ))
}

# ── Cursor & Drawing Helpers ───────────────────────────────────────────────
move_to() { printf "\033[%d;%dH" "$1" "$2"; }
clear_screen() { printf "\033[2J\033[H"; }

draw_vline() {
    local col=$1 start_row=$2 end_row=$3 char="${4:-│}"
    for (( r=start_row; r<=end_row; r++ )); do
        move_to "$r" "$col"
        printf "%s" "$char"
    done
}

print_at() {
    local row=$1 col=$2 max_width=$3
    shift 3
    local text="$*"
    move_to "$row" "$col"
    printf "%-${max_width}.${max_width}s" "$text"
}

print_at_styled() {
    local row=$1 col=$2 max_width=$3 style=$4
    shift 4
    local text="$*"
    move_to "$row" "$col"
    printf "${style}%-${max_width}.${max_width}s${RESET}" "$text"
}

# ── Time Helpers ───────────────────────────────────────────────────────────
now_epoch() { echo "${EPOCHSECONDS:-$(date +%s)}"; }

iso_to_epoch() {
    local ts="$1"
    if [[ "$OSTYPE" == darwin* ]]; then
        local clean="${ts%%.*}"
        clean="${clean}Z"
        date -j -f "%Y-%m-%dT%H:%M:%SZ" "$clean" +%s 2>/dev/null || echo 0
    else
        date -d "$ts" +%s 2>/dev/null || echo 0
    fi
}

format_elapsed() {
    local epoch="$1"
    local now
    now=$(now_epoch)
    local diff=$(( now - epoch ))

    if (( diff < 60 )); then echo "${diff}s ago"
    elif (( diff < 3600 )); then echo "$(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
    elif (( diff < 604800 )); then echo "$(( diff / 86400 ))d ago"
    else echo "$(( diff / 604800 ))w ago"
    fi
}

format_datetime() {
    local ts="$1"
    local clean="${ts%%.*}"
    clean="${clean//T/ }"
    clean="${clean//Z/}"
    echo "${clean:0:16}"
}

# ── Session Data ───────────────────────────────────────────────────────────
# List-level fields (compact load: grep 2 lines per file)
declare -a SESSION_FILES=()
declare -a SESSION_IDS=()
declare -a SESSION_ELAPSED=()
declare -a SESSION_DIRS=()
declare -a SESSION_TIMESTAMPS=()
declare -a SESSION_PROJECTS=()
declare -a SESSION_BRANCHES=()
declare -a SESSION_CWDS=()
declare -a SESSION_EPOCH=()
declare -a SESSION_FIRST_MSG=()   # first user message (session summary)
declare -a SESSION_MODELS=()      # model name from last assistant message
declare -a SESSION_CTX=()         # last context size in tokens
declare -a SESSION_FORK_FROM=()   # parent session ID (short) if forked, empty otherwise
declare -a SESSION_MODEL_SHORT=() # pre-computed short model name
declare -a SESSION_CTX_SHORT=()   # pre-computed formatted token count

CTX_WARN_THRESHOLD=80000  # show ⚠ when context exceeds this

SESSION_COUNT=0
SELECTED=0
SCROLL_OFFSET=0
SEARCH_QUERY=""
SEARCH_MODE=false
SEARCH_ACTIVE=""

COMMAND_MODE=false
COMMAND_INPUT=""
STATUS_MSG=""
STATUS_MSG_EXPIRE=0

# Detail-level fields (lazy loaded for one session at a time)
DETAIL_SID=""         # which session is currently loaded
DETAIL_LAST_MSG=""
DETAIL_MSG_COUNT=""
DETAIL_TOTAL_OUTPUT=""
DETAIL_TOOL_COUNT=""
DETAIL_TOP_TOOL=""
DETAIL_VERSION=""
DETAIL_ENTRYPOINT=""

# Group data: sessions grouped by project
declare -a GROUP_NAMES=()
declare -a GROUP_STARTS=()
declare -a GROUP_COUNTS=()
GROUP_COUNT=0

# Cache of active tmux window names (refreshed periodically)
# Windows use "s:XXXXXXXX" naming convention. We strip the prefix for matching.
# Stored as "|sid1|sid2|" for fast substring match without subprocess.
ACTIVE_WINDOWS_STR="|"
ACTIVE_WINDOWS_COUNT=0
SILENCE_WINDOWS_STR="|"
ACTIVE_WINDOWS_LAST_REFRESH=0

refresh_active_windows() {
    local now=${EPOCHSECONDS:-$(date +%s)}
    # Refresh at most every 2 seconds
    if (( now - ACTIVE_WINDOWS_LAST_REFRESH < 2 )); then
        return
    fi
    ACTIVE_WINDOWS_STR="|"
    ACTIVE_WINDOWS_COUNT=0
    SILENCE_WINDOWS_STR="|"
    if [[ -n "${TMUX:-}" ]]; then
        local name flag
        while IFS=' ' read -r name flag; do
            if [[ "$name" == s:* ]]; then
                local sid_part="${name#s:}"
                ACTIVE_WINDOWS_STR="${ACTIVE_WINDOWS_STR}${sid_part}|"
                ACTIVE_WINDOWS_COUNT=$(( ACTIVE_WINDOWS_COUNT + 1 ))
                if [[ "$flag" == "1" ]]; then
                    SILENCE_WINDOWS_STR="${SILENCE_WINDOWS_STR}${sid_part}|"
                fi
            fi
        done < <(tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name} #{window_silence_flag}' 2>/dev/null)
    fi
    ACTIVE_WINDOWS_LAST_REFRESH=$now
}

is_session_active() {
    [[ "$ACTIVE_WINDOWS_STR" == *"|${1:0:8}|"* ]]
}

is_session_needs_attention() {
    [[ "$SILENCE_WINDOWS_STR" == *"|${1:0:8}|"* ]]
}

extract_project_name() {
    local dir_name="$1"
    local stripped="${dir_name#-Users-ted-}"
    stripped="${stripped#project-}"
    echo "$stripped" | sed 's/--/\/_/g'
}

load_sessions() {
    SESSION_FILES=()
    SESSION_IDS=()
    SESSION_ELAPSED=()
    SESSION_DIRS=()
    SESSION_TIMESTAMPS=()
    SESSION_PROJECTS=()
    SESSION_BRANCHES=()
    SESSION_CWDS=()
    SESSION_EPOCH=()
    SESSION_FIRST_MSG=()
    SESSION_MODELS=()
    SESSION_CTX=()
    SESSION_FORK_FROM=()
    SESSION_MODEL_SHORT=()
    SESSION_CTX_SHORT=()
    SESSION_COUNT=0
    DETAIL_SID=""  # invalidate cached detail

    local tmpfile
    tmpfile=$(mktemp)

    find "$CLAUDE_PROJECTS_DIR" -maxdepth 2 -name "*.jsonl" ! -path "*/subagents/*" -print0 2>/dev/null \
        | xargs -0 ls -t 2>/dev/null > "$tmpfile" || true

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue

        local dir_name
        dir_name=$(basename "$(dirname "$filepath")")
        local file_name
        file_name=$(basename "$filepath" .jsonl)

        # Compact load: first user line only (has sid, cwd, branch, ts, msg)
        local first_user_line
        first_user_line=$(grep -m1 '"type":"user"' "$filepath" 2>/dev/null) || continue
        [[ -z "$first_user_line" ]] && continue

        local user_data
        user_data=$(printf '%s' "$first_user_line" | jq -r '{
            sid: (.sessionId // ""),
            ts: (.timestamp // ""),
            cwd: (.cwd // ""),
            branch: (.gitBranch // ""),
            msg: ((.message.content // "") | if type == "string" then . elif type == "array" then [.[] | if .type == "tool_result" then (.content | if type == "string" then . elif type == "array" then [.[] | select(.type == "text") | .text] | join(" ") else "" end) elif .type == "text" then .text else "" end] | join(" ") else "" end | gsub("<[^>]+>"; "") | gsub("\\s+"; " ") | ltrimstr(" ") | .[0:100])
        }' 2>/dev/null) || continue

        local sid ts cwd branch first_msg
        sid=$(printf '%s' "$user_data" | jq -r '.sid')
        ts=$(printf '%s' "$user_data" | jq -r '.ts')
        cwd=$(printf '%s' "$user_data" | jq -r '.cwd')
        branch=$(printf '%s' "$user_data" | jq -r '.branch')
        first_msg=$(printf '%s' "$user_data" | jq -r '.msg')

        [[ -z "$sid" || "$sid" == "null" ]] && sid="$file_name"
        [[ "$ts" == "null" ]] && ts=""
        [[ "$cwd" == "null" ]] && cwd=""
        [[ "$branch" == "null" ]] && branch=""
        [[ "$first_msg" == "null" ]] && first_msg=""

        # Compact load: last assistant line (has model, usage/context)
        local model="" ctx=0
        local last_asst_line
        last_asst_line=$(grep '"type":"assistant"' "$filepath" 2>/dev/null | tail -1) || true
        if [[ -n "$last_asst_line" ]]; then
            local asst_data
            asst_data=$(printf '%s' "$last_asst_line" | jq -r '{
                model: (.message.model // ""),
                ctx: ((.message.usage.input_tokens // 0) + (.message.usage.cache_creation_input_tokens // 0) + (.message.usage.cache_read_input_tokens // 0))
            }' 2>/dev/null) || true
            if [[ -n "$asst_data" ]]; then
                model=$(printf '%s' "$asst_data" | jq -r '.model')
                ctx=$(printf '%s' "$asst_data" | jq -r '.ctx')
                [[ "$model" == "null" ]] && model=""
                [[ "$ctx" == "null" ]] && ctx=0
            fi
        fi

        local epoch=0
        if [[ -n "$ts" ]]; then
            epoch=$(iso_to_epoch "$ts")
        fi

        local project_name
        project_name=$(extract_project_name "$dir_name")

        # Detect fork marker: [forked-from:XXXXXXXX]
        local fork_from=""
        if [[ "$first_msg" =~ ^\[forked-from:([a-f0-9]+)\] ]]; then
            fork_from="${BASH_REMATCH[1]}"
            # Strip marker + preamble, show the context line
            first_msg=$(printf '%s' "$first_msg" | sed 's/^\[forked-from:[a-f0-9]*\] *//')
            # Try to extract just the context part
            local ctx_line
            ctx_line=$(printf '%s' "$first_msg" | sed -n 's/.*작업 컨텍스트: *//p')
            if [[ -n "$ctx_line" ]]; then
                first_msg="$ctx_line"
            fi
        fi

        SESSION_FILES+=("$filepath")
        SESSION_IDS+=("$sid")
        SESSION_TIMESTAMPS+=("$ts")
        SESSION_DIRS+=("$dir_name")
        SESSION_PROJECTS+=("$project_name")
        SESSION_BRANCHES+=("$branch")
        SESSION_CWDS+=("$cwd")
        SESSION_EPOCH+=("$epoch")
        SESSION_FIRST_MSG+=("$first_msg")
        SESSION_MODELS+=("$model")
        SESSION_CTX+=("$ctx")
        SESSION_FORK_FROM+=("$fork_from")
        SESSION_MODEL_SHORT+=("$(format_model_short "$model")")
        SESSION_CTX_SHORT+=("$(format_tokens "$ctx")")

        if [[ -n "$ts" && "$epoch" -gt 0 ]]; then
            SESSION_ELAPSED+=("$(format_elapsed "$epoch")")
        else
            SESSION_ELAPSED+=("?")
        fi

        SESSION_COUNT=$(( SESSION_COUNT + 1 ))
    done < "$tmpfile"

    rm -f "$tmpfile"
}

# ── Lazy Detail Loading ───────────────────────────────────────────────────
# Full parse of a single session file. Called when selection changes.
format_model_short() {
    local m="$1"
    case "$m" in
        *opus*)   echo "opus" ;;
        *sonnet*) echo "sonnet" ;;
        *haiku*)  echo "haiku" ;;
        *)        echo "${m:0:12}" ;;
    esac
}

format_tokens() {
    local t="$1"
    if (( t >= 1000000 )); then
        echo "$(( t / 1000000 )).$(( (t % 1000000) / 100000 ))M"
    elif (( t >= 1000 )); then
        echo "$(( t / 1000 ))K"
    else
        echo "$t"
    fi
}

load_session_detail() {
    local idx="$1"
    local sid="${SESSION_IDS[$idx]}"

    # Skip if already loaded for this session
    if [[ "$DETAIL_SID" == "$sid" ]]; then
        return
    fi

    DETAIL_SID="$sid"
    DETAIL_LAST_MSG=""
    DETAIL_MSG_COUNT=""
    DETAIL_TOTAL_OUTPUT=""
    DETAIL_TOOL_COUNT=""
    DETAIL_TOP_TOOL=""
    DETAIL_VERSION=""
    DETAIL_ENTRYPOINT=""

    local filepath="${SESSION_FILES[$idx]}"
    [[ ! -f "$filepath" ]] && return

    local detail
    detail=$(jq -s '{
        last_msg: ([.[] | select(.type == "user") | .message.content // ""] | last // "" | if type == "string" then . elif type == "array" then [.[] | if .type == "tool_result" then (.content | if type == "string" then . elif type == "array" then [.[] | select(.type == "text") | .text] | join(" ") else "" end) elif .type == "text" then .text else "" end] | join(" ") else "" end | gsub("<[^>]+>"; "") | gsub("\\s+"; " ") | ltrimstr(" ") | .[0:120]),
        msg_count: ([.[] | select(.type == "user")] | length),
        total_output: ([.[] | select(.type == "assistant") | .message.usage.output_tokens // 0] | add // 0),
        tool_count: ([.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use")] | length),
        top_tool: ([.[] | select(.type == "assistant") | .message.content[]? | select(.type == "tool_use") | .name] | group_by(.) | sort_by(-length) | .[0][0] // "-"),
        version: ([.[] | select(.type == "user") | .version // ""] | .[0] // ""),
        entrypoint: ([.[] | select(.type == "user") | .entrypoint // ""] | .[0] // "")
    }' "$filepath" 2>/dev/null) || return

    DETAIL_LAST_MSG=$(printf '%s' "$detail" | jq -r '.last_msg')
    DETAIL_MSG_COUNT=$(printf '%s' "$detail" | jq -r '.msg_count')
    DETAIL_TOTAL_OUTPUT=$(printf '%s' "$detail" | jq -r '.total_output')
    DETAIL_TOOL_COUNT=$(printf '%s' "$detail" | jq -r '.tool_count')
    DETAIL_TOP_TOOL=$(printf '%s' "$detail" | jq -r '.top_tool')
    DETAIL_VERSION=$(printf '%s' "$detail" | jq -r '.version')
    DETAIL_ENTRYPOINT=$(printf '%s' "$detail" | jq -r '.entrypoint')

    if [[ "$DETAIL_LAST_MSG" == "null" ]]; then DETAIL_LAST_MSG=""; fi
    if [[ "$DETAIL_TOP_TOOL" == "null" ]]; then DETAIL_TOP_TOOL="-"; fi
}

# ── Group sessions by project ─────────────────────────────────────────────
# Reorders SESSION_* arrays so sessions in the same project are contiguous.
# Groups are sorted by the most recent session within each group (already
# the first occurrence since sessions are loaded newest-first).

group_sessions() {
    GROUP_NAMES=()
    GROUP_STARTS=()
    GROUP_COUNTS=()
    GROUP_COUNT=0

    if (( SESSION_COUNT == 0 )); then
        return
    fi

    # Collect unique project names in first-seen order (= most-recent-first)
    local -a seen_projects=()
    local -a order=()  # maps: flat index in new order → original index
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local proj="${SESSION_PROJECTS[$i]}"
        local found=false
        for sp in "${seen_projects[@]+"${seen_projects[@]}"}"; do
            if [[ "$sp" == "$proj" ]]; then
                found=true
                break
            fi
        done
        if ! $found; then
            seen_projects+=("$proj")
        fi
    done

    # Build reordered index: for each project, collect its session indices
    for proj in "${seen_projects[@]}"; do
        local start=${#order[@]}
        local count=0
        for (( i=0; i<SESSION_COUNT; i++ )); do
            if [[ "${SESSION_PROJECTS[$i]}" == "$proj" ]]; then
                order+=("$i")
                count=$(( count + 1 ))
            fi
        done
        GROUP_NAMES+=("$proj")
        GROUP_STARTS+=("$start")
        GROUP_COUNTS+=("$count")
        GROUP_COUNT=$(( GROUP_COUNT + 1 ))
    done

    # Reorder all SESSION_* arrays according to order[]
    local -a nw_FILES=() nw_IDS=() nw_ELAPSED=() nw_DIRS=()
    local -a nw_TIMESTAMPS=() nw_PROJECTS=() nw_BRANCHES=()
    local -a nw_FIRST_MSG=() nw_CWDS=() nw_EPOCH=()
    local -a nw_MODELS=() nw_CTX=() nw_FORK_FROM=()
    local -a nw_MODEL_SHORT=() nw_CTX_SHORT=()

    for idx in "${order[@]}"; do
        nw_FILES+=("${SESSION_FILES[$idx]}")
        nw_IDS+=("${SESSION_IDS[$idx]}")
        nw_ELAPSED+=("${SESSION_ELAPSED[$idx]}")
        nw_DIRS+=("${SESSION_DIRS[$idx]}")
        nw_TIMESTAMPS+=("${SESSION_TIMESTAMPS[$idx]}")
        nw_PROJECTS+=("${SESSION_PROJECTS[$idx]}")
        nw_BRANCHES+=("${SESSION_BRANCHES[$idx]}")
        nw_FIRST_MSG+=("${SESSION_FIRST_MSG[$idx]}")
        nw_CWDS+=("${SESSION_CWDS[$idx]}")
        nw_EPOCH+=("${SESSION_EPOCH[$idx]}")
        nw_MODELS+=("${SESSION_MODELS[$idx]}")
        nw_CTX+=("${SESSION_CTX[$idx]}")
        nw_FORK_FROM+=("${SESSION_FORK_FROM[$idx]}")
        nw_MODEL_SHORT+=("${SESSION_MODEL_SHORT[$idx]}")
        nw_CTX_SHORT+=("${SESSION_CTX_SHORT[$idx]}")
    done

    SESSION_FILES=("${nw_FILES[@]}")
    SESSION_IDS=("${nw_IDS[@]}")
    SESSION_ELAPSED=("${nw_ELAPSED[@]}")
    SESSION_DIRS=("${nw_DIRS[@]}")
    SESSION_TIMESTAMPS=("${nw_TIMESTAMPS[@]}")
    SESSION_PROJECTS=("${nw_PROJECTS[@]}")
    SESSION_BRANCHES=("${nw_BRANCHES[@]}")
    SESSION_FIRST_MSG=("${nw_FIRST_MSG[@]}")
    SESSION_CWDS=("${nw_CWDS[@]}")
    SESSION_EPOCH=("${nw_EPOCH[@]}")
    SESSION_MODELS=("${nw_MODELS[@]}")
    SESSION_CTX=("${nw_CTX[@]}")
    SESSION_FORK_FROM=("${nw_FORK_FROM[@]}")
    SESSION_MODEL_SHORT=("${nw_MODEL_SHORT[@]}")
    SESSION_CTX_SHORT=("${nw_CTX_SHORT[@]}")
}

# ── Search with BM25 scoring ──────────────────────────────────────────────
# Searches all user messages in each session's .jsonl file.
# Scores results using simplified BM25: TF * IDF component.
# Results are sorted by score descending; non-matching sessions are hidden.

search_sessions() {
    local query="$1"
    if [[ -z "$query" ]]; then
        return
    fi

    local query_lower
    query_lower=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')

    # Split query into terms
    local -a terms=()
    for word in $query_lower; do
        [[ -n "$word" ]] && terms+=("$word")
    done
    if [[ ${#terms[@]} -eq 0 ]]; then
        return
    fi

    local total_docs=$SESSION_COUNT
    if (( total_docs == 0 )); then
        return
    fi

    # For each session, compute BM25 score by searching full .jsonl content
    local -a scored_indices=()
    local -a scored_values=()
    local k1=1200  # BM25 k1 * 1000 (integer math, 1.2 → 1200)
    local b=750    # BM25 b * 1000 (0.75 → 750)

    # Compute average document length (word count of all user messages)
    local total_words=0
    local -a doc_lengths=()
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local wc
        wc=$(jq -s -r '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | split(" ") | length' \
            "${SESSION_FILES[$i]}" 2>/dev/null) || wc=0
        doc_lengths+=("$wc")
        total_words=$(( total_words + wc ))
    done
    local avg_dl=$(( total_words / (total_docs > 0 ? total_docs : 1) ))
    (( avg_dl == 0 )) && avg_dl=1

    # Count document frequency for each term (how many sessions contain it)
    local -a df=()
    for (( t=0; t<${#terms[@]}; t++ )); do
        local term_df=0
        for (( i=0; i<SESSION_COUNT; i++ )); do
            if jq -s -e --arg q "${terms[$t]}" \
                '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | ascii_downcase | test($q)' \
                "${SESSION_FILES[$i]}" >/dev/null 2>&1; then
                term_df=$(( term_df + 1 ))
            fi
        done
        df+=("$term_df")
    done

    # Score each session
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local score=0
        local dl="${doc_lengths[$i]}"
        local matched=false

        # Get all user message text for this session (lowercase)
        local all_text
        all_text=$(jq -s -r '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | ascii_downcase' \
            "${SESSION_FILES[$i]}" 2>/dev/null) || all_text=""

        for (( t=0; t<${#terms[@]}; t++ )); do
            local term="${terms[$t]}"
            local tdf="${df[$t]}"

            # Term frequency: count occurrences
            local tf=0
            if [[ -n "$all_text" ]]; then
                # Count non-overlapping occurrences
                local stripped="${all_text//$term/}"
                local term_len=${#term}
                if (( term_len > 0 )); then
                    tf=$(( (${#all_text} - ${#stripped}) / term_len ))
                fi
            fi

            if (( tf > 0 )); then
                matched=true

                # IDF = ln((N - df + 0.5) / (df + 0.5)) * 1000
                # Simplified: higher when term is rarer
                local idf
                if (( tdf == 0 )); then
                    idf=1000
                else
                    # (N - df) / df * 1000 as approximation
                    idf=$(( (total_docs - tdf) * 1000 / tdf ))
                fi
                (( idf < 100 )) && idf=100

                # BM25 TF component: tf * (k1 + 1000) / (tf * 1000 + k1 * (1000 - b + b * dl * 1000 / avg_dl) / 1000)
                # Simplified integer approximation:
                local norm=$(( 1000 - b + b * dl / avg_dl ))
                local denom=$(( tf * 1000 + k1 * norm / 1000 ))
                local tf_score=0
                if (( denom > 0 )); then
                    tf_score=$(( tf * (k1 + 1000) * 1000 / denom ))
                fi

                score=$(( score + tf_score * idf / 1000 ))
            fi
        done

        if $matched; then
            scored_indices+=("$i")
            scored_values+=("$score")
        fi
    done

    # Sort by score descending — rebuild arrays in score order
    local count=${#scored_indices[@]}
    if (( count == 0 )); then
        SESSION_FILES=()
        SESSION_IDS=()
        SESSION_ELAPSED=()
        SESSION_DIRS=()
        SESSION_TIMESTAMPS=()
        SESSION_PROJECTS=()
        SESSION_BRANCHES=()
        SESSION_FIRST_MSG=()
        SESSION_CWDS=()
        SESSION_EPOCH=()
        SESSION_MODELS=()
        SESSION_CTX=()
        SESSION_FORK_FROM=()
        SESSION_MODEL_SHORT=()
        SESSION_CTX_SHORT=()
        SESSION_COUNT=0
        return
    fi

    # Bubble sort indices by score (small N, fine for ~100 sessions)
    for (( a=0; a<count-1; a++ )); do
        for (( c=0; c<count-a-1; c++ )); do
            if (( scored_values[c] < scored_values[c+1] )); then
                local tmp_i="${scored_indices[$c]}"
                scored_indices[$c]="${scored_indices[$((c+1))]}"
                scored_indices[$((c+1))]="$tmp_i"
                local tmp_s="${scored_values[$c]}"
                scored_values[$c]="${scored_values[$((c+1))]}"
                scored_values[$((c+1))]="$tmp_s"
            fi
        done
    done

    # Rebuild arrays in sorted order
    local -a new_FILES=() new_IDS=() new_ELAPSED=() new_DIRS=()
    local -a new_TIMESTAMPS=() new_PROJECTS=() new_BRANCHES=()
    local -a new_FIRST_MSG=() new_CWDS=() new_EPOCH=()
    local -a new_MODELS=() new_CTX=() new_FORK_FROM=()
    local -a new_MODEL_SHORT=() new_CTX_SHORT=()

    for (( x=0; x<count; x++ )); do
        local idx="${scored_indices[$x]}"
        new_FILES+=("${SESSION_FILES[$idx]}")
        new_IDS+=("${SESSION_IDS[$idx]}")
        new_ELAPSED+=("${SESSION_ELAPSED[$idx]}")
        new_DIRS+=("${SESSION_DIRS[$idx]}")
        new_TIMESTAMPS+=("${SESSION_TIMESTAMPS[$idx]}")
        new_PROJECTS+=("${SESSION_PROJECTS[$idx]}")
        new_BRANCHES+=("${SESSION_BRANCHES[$idx]}")
        new_FIRST_MSG+=("${SESSION_FIRST_MSG[$idx]}")
        new_CWDS+=("${SESSION_CWDS[$idx]}")
        new_EPOCH+=("${SESSION_EPOCH[$idx]}")
        new_MODELS+=("${SESSION_MODELS[$idx]}")
        new_CTX+=("${SESSION_CTX[$idx]}")
        new_FORK_FROM+=("${SESSION_FORK_FROM[$idx]}")
        new_MODEL_SHORT+=("${SESSION_MODEL_SHORT[$idx]}")
        new_CTX_SHORT+=("${SESSION_CTX_SHORT[$idx]}")
    done

    SESSION_FILES=("${new_FILES[@]}")
    SESSION_IDS=("${new_IDS[@]}")
    SESSION_ELAPSED=("${new_ELAPSED[@]}")
    SESSION_DIRS=("${new_DIRS[@]}")
    SESSION_TIMESTAMPS=("${new_TIMESTAMPS[@]}")
    SESSION_PROJECTS=("${new_PROJECTS[@]}")
    SESSION_BRANCHES=("${new_BRANCHES[@]}")
    SESSION_FIRST_MSG=("${new_FIRST_MSG[@]}")
    SESSION_CWDS=("${new_CWDS[@]}")
    SESSION_EPOCH=("${new_EPOCH[@]}")
    SESSION_MODELS=("${new_MODELS[@]}")
    SESSION_CTX=("${new_CTX[@]}")
    SESSION_FORK_FROM=("${new_FORK_FROM[@]}")
    SESSION_MODEL_SHORT=("${new_MODEL_SHORT[@]}")
    SESSION_CTX_SHORT=("${new_CTX_SHORT[@]}")
    SESSION_COUNT=$count
}

# ── Fork Session ───────────────────────────────────────────────────────────
fork_session() {
    local idx="$1"
    local parent_sid="${SESSION_IDS[$idx]}"
    local parent_sid_short="${parent_sid:0:8}"
    local cwd="${SESSION_CWDS[$idx]}"
    local first_msg="${SESSION_FIRST_MSG[$idx]}"
    local branch="${SESSION_BRANCHES[$idx]}"

    # Build fork prompt
    local fork_prompt="[forked-from:${parent_sid_short}] 이전 세션(${parent_sid_short})의 작업을 이어갑니다. 작업 컨텍스트: ${first_msg}"
    if [[ -n "$branch" ]]; then
        fork_prompt="${fork_prompt} (branch: ${branch})"
    fi
    fork_prompt="${fork_prompt}

이전 세션의 context가 커서 새 세션으로 fork했습니다. 위 맥락을 기반으로 작업을 계속해주세요."

    local cd_cmd=""
    if [[ -n "$cwd" && -d "$cwd" ]]; then
        cd_cmd="cd $(printf '%q' "$cwd") && "
    fi

    if [[ -z "${TMUX:-}" ]]; then
        # Non-tmux fallback: direct launch
        tput rmcup; tput cnorm
        if [[ -n "$ORIG_STTY" ]]; then stty "$ORIG_STTY" 2>/dev/null || true; fi
        clear_screen
        if [[ -n "$cwd" && -d "$cwd" ]]; then cd "$cwd"; fi
        set +e
        claude "$fork_prompt"
        set -e
        tput smcup; tput civis; stty -echo -icanon min 1 time 0
        clear_screen
        return
    fi

    # Write prompt to temp file (handles long/multiline prompts safely)
    local prompt_file="/tmp/ssread_fork_$$_$(date +%s)"
    printf '%s' "$fork_prompt" > "$prompt_file"

    pane_detach_current
    local win_name="s:f${parent_sid_short}"
    tmux new-window -d -t "$TMUX_SESSION_NAME" -n "$win_name" \
        "${cd_cmd}claude \"\$(cat '${prompt_file}')\" ; rm -f '${prompt_file}'; echo ''; echo 'Session ended. Press any key to close.'; read -rsn1"
    tmux set-option -t "$TMUX_SESSION_NAME:$win_name" monitor-silence 15 2>/dev/null || true
    _create_split_layout "$win_name"
    ATTACHED_SID="fork:${parent_sid_short}"
}

# ── Command Mode ───────────────────────────────────────────────────────────
set_status_msg() {
    STATUS_MSG="$1"
    STATUS_MSG_EXPIRE=$(( ${EPOCHSECONDS:-$(date +%s)} + 3 ))
}

# Launch a brand-new claude session
cmd_new_session() {
    local root="" prompt="" branch=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root|-r)
                if [[ -z "${2:-}" ]]; then
                    set_status_msg "Error: --root requires a path"
                    return 1
                fi
                root="$2"; shift 2 ;;
            --prompt|-p)
                if [[ -z "${2:-}" ]]; then
                    set_status_msg "Error: --prompt requires a value"
                    return 1
                fi
                prompt="$2"; shift 2 ;;
            --branch|-b)
                if [[ -z "${2:-}" ]]; then
                    set_status_msg "Error: --branch requires a value"
                    return 1
                fi
                branch="$2"; shift 2 ;;
            *)
                set_status_msg "Error: unknown option: $1"
                return 1 ;;
        esac
    done

    # Validate root
    if [[ -z "$root" ]]; then
        set_status_msg "Error: --root is required"
        return 1
    fi

    # Expand ~ manually
    if [[ "$root" == "~"* ]]; then
        root="${HOME}${root:1}"
    fi

    if [[ ! -d "$root" ]]; then
        set_status_msg "Error: directory not found: $root"
        return 1
    fi

    # Validate branch
    if [[ -n "$branch" ]]; then
        if [[ ! -d "$root/.git" ]] && ! git -C "$root" rev-parse --git-dir &>/dev/null; then
            set_status_msg "Error: not a git repository: $root"
            return 1
        fi
        if ! git -C "$root" rev-parse --verify "$branch" &>/dev/null; then
            set_status_msg "Error: branch not found: $branch"
            return 1
        fi
    fi

    # Build command
    local cd_cmd="cd $(printf '%q' "$root") && "
    local branch_cmd=""
    if [[ -n "$branch" ]]; then
        branch_cmd="git checkout $(printf '%q' "$branch") && "
    fi

    local claude_cmd="claude"
    if [[ -n "$prompt" ]]; then
        local prompt_file="/tmp/ssread_new_$$_$(date +%s)"
        printf '%s' "$prompt" > "$prompt_file"
        claude_cmd="claude \"\$(cat '${prompt_file}')\" ; rm -f '${prompt_file}'"
    fi

    local win_name="new"
    if [[ -n "$branch" ]]; then
        win_name="${branch:0:16}"
    fi

    if [[ -z "${TMUX:-}" ]]; then
        tput rmcup; tput cnorm
        if [[ -n "$ORIG_STTY" ]]; then stty "$ORIG_STTY" 2>/dev/null || true; fi
        clear_screen
        cd "$root"
        if [[ -n "$branch" ]]; then git checkout "$branch"; fi
        set +e
        if [[ -n "$prompt" ]]; then
            claude "$prompt"
        else
            claude
        fi
        set -e
        tput smcup; tput civis; stty -echo -icanon min 1 time 0
        clear_screen
    else
        pane_detach_current
        local pane_win_name="s:${win_name}"
        tmux new-window -d -t "$TMUX_SESSION_NAME" -n "$pane_win_name" \
            "${cd_cmd}${branch_cmd}${claude_cmd}; echo ''; echo 'Session ended. Press any key to close.'; read -rsn1"
        tmux set-option -t "$TMUX_SESSION_NAME:$pane_win_name" monitor-silence 15 2>/dev/null || true
        _create_split_layout "$pane_win_name"
        ATTACHED_SID="new:${win_name}"
    fi

    # Refresh session list after short delay for the new session to register
    set_status_msg "New session launched in $root"
    load_sessions
    group_sessions
}

execute_command() {
    local input="$1"

    # Tokenize respecting quoted strings
    local -a tokens=()
    local token="" in_quote="" quote_char=""
    local i=0
    while (( i < ${#input} )); do
        local ch="${input:$i:1}"
        if [[ -n "$in_quote" ]]; then
            if [[ "$ch" == "$quote_char" ]]; then
                in_quote=""
            else
                token+="$ch"
            fi
        elif [[ "$ch" == '"' || "$ch" == "'" ]]; then
            in_quote=1
            quote_char="$ch"
        elif [[ "$ch" == " " ]]; then
            if [[ -n "$token" ]]; then
                tokens+=("$token")
                token=""
            fi
        else
            token+="$ch"
        fi
        (( i++ ))
    done
    [[ -n "$token" ]] && tokens+=("$token")

    if [[ ${#tokens[@]} -eq 0 ]]; then
        return
    fi

    local cmd="${tokens[0]}"
    local args=("${tokens[@]:1}")

    case "$cmd" in
        new)
            cmd_new_session "${args[@]+"${args[@]}"}"
            ;;
        *)
            set_status_msg "Unknown command: $cmd"
            ;;
    esac
}

# ── Session Launch (fallback for non-tmux) ─────────────────────────────────
launch_session_direct() {
    local sid="$1"
    local cwd="$2"

    tput rmcup
