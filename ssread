    printf "${BOLD}${FG_CYAN}ssread${RESET}${FG_GRAY} loading sessions...${RESET}"
}

PREV_RIGHT_WIDTH=-1

render() {
    get_dimensions
    refresh_active_windows
    SPINNER_IDX=$(( (SPINNER_IDX + 1) % 3 ))
    # Deferred auto-refresh: reload sessions after new/fork creates a session
    if (( REFRESH_AFTER_CYCLES > 0 )); then
        REFRESH_AFTER_CYCLES=$(( REFRESH_AFTER_CYCLES - 1 ))
        if (( REFRESH_AFTER_CYCLES == 0 )); then
            load_sessions
            group_sessions
            build_display_list
        fi
    fi
    # In 3-pane layout, ssread is always in the left pane (list only)
    if $LAYOUT_ACTIVE; then
        LEFT_WIDTH=$(( TERM_COLS - 2 ))
        RIGHT_WIDTH=0
        # Update detail file for the watcher pane
        write_detail_file
    elif (( TERM_COLS < 80 )); then
        LEFT_WIDTH=$(( TERM_COLS - 2 ))
        RIGHT_WIDTH=0
    fi
    # Clear screen on layout mode change to avoid ghost text
    if (( RIGHT_WIDTH != PREV_RIGHT_WIDTH )); then
        clear_screen
        CACHED_BORDER_ROWS=0  # force border redraw
        PREV_RIGHT_WIDTH=$RIGHT_WIDTH
    fi
    local buf
    buf=$(
        draw_border
        draw_left_header
        if (( RIGHT_WIDTH > 0 )); then
            draw_right_header
        fi
        draw_session_list
        if (( RIGHT_WIDTH > 0 )); then
            draw_detail_panel
        fi
        draw_status_bar
    )
    printf "%s" "$buf"
}

