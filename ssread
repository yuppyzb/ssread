#!/usr/bin/env bash
# ssread — Claude Code session manager TUI
# Browse sessions from ~/.claude/projects/ and launch them in tmux windows
# Each session runs in its own tmux window for parallel task management

set -euo pipefail

# ── Configuration ──────────────────────────────────────────────────────────
CLAUDE_PROJECTS_DIR="$HOME/.claude/projects"
SSREAD_TMUX_SESSION="ssread"
SSREAD_INSIDE_TMUX="${SSREAD_INSIDE_TMUX:-}"

# ── Color & Style ──────────────────────────────────────────────────────────
# Use $'...' so variables hold real ESC bytes, not literal \033 strings.
# This ensures colors work both in printf format strings AND in %s arguments.
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'
REV=$'\033[7m'
FG_CYAN=$'\033[36m'
FG_YELLOW=$'\033[33m'
FG_GREEN=$'\033[32m'
FG_WHITE=$'\033[37m'
FG_GRAY=$'\033[90m'
FG_BLUE=$'\033[34m'
FG_MAGENTA=$'\033[35m'
BG_DARK=$'\033[48;5;235m'

# ── Dependency Check ───────────────────────────────────────────────────────
check_dependencies() {
    local missing=()
    command -v jq &>/dev/null || missing+=("jq")
    command -v tmux &>/dev/null || missing+=("tmux")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Error: missing dependencies: ${missing[*]}"
        echo "  brew install ${missing[*]}  (macOS)"
        echo "  apt install ${missing[*]}   (Ubuntu/Debian)"
        exit 1
    fi
}

# ── tmux Bootstrap ─────────────────────────────────────────────────────────
# If not inside our tmux session, create/attach to one and re-exec ssread inside it.
ensure_tmux_session() {
    # Already inside our tmux session — nothing to do
    if [[ -n "$SSREAD_INSIDE_TMUX" ]]; then
        return
    fi

    # Already in tmux but not our session — create a new session grouped or standalone
    if [[ -n "${TMUX:-}" ]]; then
        # We're in some other tmux session. Warn and launch inside current tmux.
        SSREAD_INSIDE_TMUX=1
        return
    fi

    # Not in tmux at all — create or attach to ssread session
    if tmux has-session -t "$SSREAD_TMUX_SESSION" 2>/dev/null; then
        # Session exists — attach to it (ssread TUI should be in window 0)
        exec tmux attach-session -t "$SSREAD_TMUX_SESSION"
    else
        # Create new session with ssread TUI in window 0
        exec tmux new-session -s "$SSREAD_TMUX_SESSION" -n "list" \
            "SSREAD_INSIDE_TMUX=1 $(printf '%q' "$0") $(printf '%q ' "$@")"
    fi
}

# ── tmux Window Management ────────────────────────────────────────────────
TMUX_SESSION_NAME=""

# Get the tmux session name we're running in
get_tmux_session_name() {
    if [[ -n "${TMUX:-}" ]]; then
        TMUX_SESSION_NAME=$(tmux display-message -p '#S' 2>/dev/null || echo "")
    else
        TMUX_SESSION_NAME=""
    fi
}

# Check if a claude session is already running in a tmux window.
# Returns the window index if found, empty string if not.
tmux_find_session_window() {
    local sid="$1"
    local sid_short="${sid:0:8}"

    if [[ -z "${TMUX:-}" ]]; then
        echo ""
        return
    fi

    # Search window names for our session ID prefix
    tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_index} #{window_name}' 2>/dev/null \
        | while IFS=' ' read -r idx name; do
            if [[ "$name" == "$sid_short" ]]; then
                echo "$idx"
                return
            fi
        done
}

# Get list of all active session IDs (running in tmux windows)
tmux_active_session_ids() {
    if [[ -z "${TMUX:-}" ]]; then
        return
    fi

    tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name}' 2>/dev/null \
        | grep -v '^list$' || true
}

# Launch a claude session in a new tmux window
tmux_launch_session() {
    local sid="$1"
    local cwd="$2"
    local sid_short="${sid:0:8}"

    if [[ -z "${TMUX:-}" ]]; then
        # Fallback: not in tmux, launch directly (old behavior)
        launch_session_direct "$sid" "$cwd"
        return
    fi

    local cd_cmd=""
    if [[ -n "$cwd" && -d "$cwd" ]]; then
        cd_cmd="cd $(printf '%q' "$cwd") && "
    fi

    tmux new-window -t "$TMUX_SESSION_NAME" -n "$sid_short" \
        "${cd_cmd}claude --resume '$sid'; echo ''; echo 'Session ended. Press any key to close.'; read -rsn1"
}

# Switch to an existing tmux window running a session
tmux_switch_to_window() {
    local window_idx="$1"
    tmux select-window -t "$TMUX_SESSION_NAME:$window_idx" 2>/dev/null || true
}

# Switch back to ssread list window (window 0 / "list")
tmux_switch_to_list() {
    tmux select-window -t "$TMUX_SESSION_NAME:list" 2>/dev/null \
        || tmux select-window -t "$TMUX_SESSION_NAME:0" 2>/dev/null || true
}

# Kill all claude windows (not the list window)
tmux_kill_all_sessions() {
    if [[ -z "${TMUX:-}" ]]; then
        return
    fi

    tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_index} #{window_name}' 2>/dev/null \
        | while IFS=' ' read -r idx name; do
            if [[ "$name" != "list" ]]; then
                tmux kill-window -t "$TMUX_SESSION_NAME:$idx" 2>/dev/null || true
            fi
        done
}

# Count active claude windows
tmux_active_count() {
    if [[ -z "${TMUX:-}" ]]; then
        echo 0
        return
    fi

    local count
    count=$(tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name}' 2>/dev/null \
        | grep -cv '^list$' 2>/dev/null) || count=0
    echo "$count"
}

# ── Terminal Setup ─────────────────────────────────────────────────────────
TERM_ROWS=0
TERM_COLS=0
LEFT_WIDTH=0
RIGHT_WIDTH=0
ORIG_STTY=""

setup_terminal() {
    ORIG_STTY=$(stty -g 2>/dev/null || true)
    tput smcup        # alternate screen buffer
    tput civis        # hide cursor
    stty -echo -icanon min 1 time 0
    trap cleanup EXIT INT TERM
}

cleanup() {
    tput rmcup        # restore screen
    tput cnorm        # show cursor
    if [[ -n "$ORIG_STTY" ]]; then
        stty "$ORIG_STTY" 2>/dev/null || true
    else
        stty echo icanon 2>/dev/null || true
    fi
}

get_dimensions() {
    TERM_ROWS=$(tput lines)
    TERM_COLS=$(tput cols)
    LEFT_WIDTH=$(( TERM_COLS * 45 / 100 ))
    RIGHT_WIDTH=$(( TERM_COLS - LEFT_WIDTH - 1 ))
}

# ── Cursor & Drawing Helpers ───────────────────────────────────────────────
move_to() { printf "\033[%d;%dH" "$1" "$2"; }
clear_screen() { printf "\033[2J\033[H"; }

draw_vline() {
    local col=$1 start_row=$2 end_row=$3 char="${4:-│}"
    for (( r=start_row; r<=end_row; r++ )); do
        move_to "$r" "$col"
        printf "%s" "$char"
    done
}

print_at() {
    local row=$1 col=$2 max_width=$3
    shift 3
    local text="$*"
    move_to "$row" "$col"
    printf "%-${max_width}.${max_width}s" "$text"
}

print_at_styled() {
    local row=$1 col=$2 max_width=$3 style=$4
    shift 4
    local text="$*"
    move_to "$row" "$col"
    printf "${style}%-${max_width}.${max_width}s${RESET}" "$text"
}

# ── Time Helpers ───────────────────────────────────────────────────────────
now_epoch() { date +%s; }

iso_to_epoch() {
    local ts="$1"
    if [[ "$OSTYPE" == darwin* ]]; then
        local clean="${ts%%.*}"
        clean="${clean}Z"
        date -j -f "%Y-%m-%dT%H:%M:%SZ" "$clean" +%s 2>/dev/null || echo 0
    else
        date -d "$ts" +%s 2>/dev/null || echo 0
    fi
}

format_elapsed() {
    local epoch="$1"
    local now
    now=$(now_epoch)
    local diff=$(( now - epoch ))

    if (( diff < 60 )); then echo "${diff}s ago"
    elif (( diff < 3600 )); then echo "$(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
    elif (( diff < 604800 )); then echo "$(( diff / 86400 ))d ago"
    else echo "$(( diff / 604800 ))w ago"
    fi
}

format_datetime() {
    local ts="$1"
    local clean="${ts%%.*}"
    clean="${clean//T/ }"
    clean="${clean//Z/}"
    echo "${clean:0:16}"
}

# ── Session Data ───────────────────────────────────────────────────────────
declare -a SESSION_FILES=()
declare -a SESSION_IDS=()
declare -a SESSION_TYPES=()
declare -a SESSION_ELAPSED=()
declare -a SESSION_DIRS=()
declare -a SESSION_LAST_MSG=()
declare -a SESSION_TIMESTAMPS=()
declare -a SESSION_PROJECTS=()
declare -a SESSION_BRANCHES=()
declare -a SESSION_VERSIONS=()
declare -a SESSION_FIRST_MSG=()
declare -a SESSION_MSG_COUNTS=()
declare -a SESSION_CWDS=()
declare -a SESSION_EPOCH=()

SESSION_COUNT=0
SELECTED=0
SCROLL_OFFSET=0
SEARCH_QUERY=""
SEARCH_MODE=false
SEARCH_ACTIVE=""  # The query that was actually executed (on Enter)

# Group data: sessions grouped by project
declare -a GROUP_NAMES=()      # unique project names in display order
declare -a GROUP_STARTS=()     # index into SESSION_* where each group begins
declare -a GROUP_COUNTS=()     # number of sessions per group
GROUP_COUNT=0

# Cache of active tmux window names (refreshed periodically)
ACTIVE_WINDOWS=""
ACTIVE_WINDOWS_LAST_REFRESH=0

refresh_active_windows() {
    local now
    now=$(now_epoch)
    # Refresh at most every 2 seconds
    if (( now - ACTIVE_WINDOWS_LAST_REFRESH < 2 )); then
        return
    fi
    ACTIVE_WINDOWS=$(tmux_active_session_ids)
    ACTIVE_WINDOWS_LAST_REFRESH=$now
}

is_session_active() {
    local sid="$1"
    local sid_short="${sid:0:8}"
    echo "$ACTIVE_WINDOWS" | grep -qF "$sid_short" 2>/dev/null
}

extract_project_name() {
    local dir_name="$1"
    local stripped="${dir_name#-Users-ted-}"
    stripped="${stripped#project-}"
    echo "$stripped" | sed 's/--/\/_/g'
}

load_sessions() {
    SESSION_FILES=()
    SESSION_IDS=()
    SESSION_TYPES=()
    SESSION_ELAPSED=()
    SESSION_DIRS=()
    SESSION_LAST_MSG=()
    SESSION_TIMESTAMPS=()
    SESSION_PROJECTS=()
    SESSION_BRANCHES=()
    SESSION_VERSIONS=()
    SESSION_FIRST_MSG=()
    SESSION_MSG_COUNTS=()
    SESSION_CWDS=()
    SESSION_EPOCH=()
    SESSION_COUNT=0

    local tmpfile
    tmpfile=$(mktemp)

    find "$CLAUDE_PROJECTS_DIR" -maxdepth 2 -name "*.jsonl" ! -path "*/subagents/*" -print0 2>/dev/null \
        | xargs -0 ls -t 2>/dev/null > "$tmpfile" || true

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue

        local dir_name
        dir_name=$(basename "$(dirname "$filepath")")
        local file_name
        file_name=$(basename "$filepath" .jsonl)

        local session_data
        session_data=$(jq -r -s '
            [.[] | select(.type == "user")] |
            if length == 0 then
                {sid: "", etype: "", ts: "", cwd: "", branch: "", ver: "", first_msg: "", last_msg: "", count: 0}
            else
                {
                    sid: (.[0].sessionId // ""),
                    etype: (.[0].entrypoint // "cli"),
                    ts: (.[0].timestamp // ""),
                    cwd: (.[0].cwd // ""),
                    branch: (.[0].gitBranch // ""),
                    ver: (.[0].version // ""),
                    first_msg: ((.[0].message.content // "") | if type == "string" then . else (.[0] // "" | tostring) end | .[0:120]),
                    last_msg: ((.[length-1].message.content // "") | if type == "string" then . else (.[0] // "" | tostring) end | .[0:120]),
                    count: length
                }
            end
        ' "$filepath" 2>/dev/null) || continue

        local sid etype ts cwd branch ver first_msg last_msg msg_count
        sid=$(echo "$session_data" | jq -r '.sid')
        etype=$(echo "$session_data" | jq -r '.etype')
        ts=$(echo "$session_data" | jq -r '.ts')
        cwd=$(echo "$session_data" | jq -r '.cwd')
        branch=$(echo "$session_data" | jq -r '.branch')
        ver=$(echo "$session_data" | jq -r '.ver')
        first_msg=$(echo "$session_data" | jq -r '.first_msg')
        last_msg=$(echo "$session_data" | jq -r '.last_msg')
        msg_count=$(echo "$session_data" | jq -r '.count')

        [[ -z "$sid" || "$sid" == "null" ]] && sid="$file_name"
        [[ "$ts" == "null" ]] && ts=""
        [[ "$cwd" == "null" ]] && cwd=""
        [[ "$branch" == "null" ]] && branch=""
        [[ "$ver" == "null" ]] && ver=""
        [[ "$first_msg" == "null" ]] && first_msg=""
        [[ "$last_msg" == "null" ]] && last_msg=""

        # Search filtering is handled after loading all sessions (search_sessions)
        # Here we just load everything

        local epoch=0
        if [[ -n "$ts" ]]; then
            epoch=$(iso_to_epoch "$ts")
        fi

        local project_name
        project_name=$(extract_project_name "$dir_name")

        SESSION_FILES+=("$filepath")
        SESSION_IDS+=("$sid")
        SESSION_TYPES+=("$etype")
        SESSION_TIMESTAMPS+=("$ts")
        SESSION_DIRS+=("$dir_name")
        SESSION_LAST_MSG+=("$last_msg")
        SESSION_PROJECTS+=("$project_name")
        SESSION_BRANCHES+=("$branch")
        SESSION_VERSIONS+=("$ver")
        SESSION_FIRST_MSG+=("$first_msg")
        SESSION_MSG_COUNTS+=("$msg_count")
        SESSION_CWDS+=("$cwd")
        SESSION_EPOCH+=("$epoch")

        if [[ -n "$ts" && "$epoch" -gt 0 ]]; then
            SESSION_ELAPSED+=("$(format_elapsed "$epoch")")
        else
            SESSION_ELAPSED+=("?")
        fi

        SESSION_COUNT=$(( SESSION_COUNT + 1 ))
    done < "$tmpfile"

    rm -f "$tmpfile"
}

# ── Group sessions by project ─────────────────────────────────────────────
# Reorders SESSION_* arrays so sessions in the same project are contiguous.
# Groups are sorted by the most recent session within each group (already
# the first occurrence since sessions are loaded newest-first).

group_sessions() {
    GROUP_NAMES=()
    GROUP_STARTS=()
    GROUP_COUNTS=()
    GROUP_COUNT=0

    if (( SESSION_COUNT == 0 )); then
        return
    fi

    # Collect unique project names in first-seen order (= most-recent-first)
    local -a seen_projects=()
    local -a order=()  # maps: flat index in new order → original index
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local proj="${SESSION_PROJECTS[$i]}"
        local found=false
        for sp in "${seen_projects[@]+"${seen_projects[@]}"}"; do
            if [[ "$sp" == "$proj" ]]; then
                found=true
                break
            fi
        done
        if ! $found; then
            seen_projects+=("$proj")
        fi
    done

    # Build reordered index: for each project, collect its session indices
    for proj in "${seen_projects[@]}"; do
        local start=${#order[@]}
        local count=0
        for (( i=0; i<SESSION_COUNT; i++ )); do
            if [[ "${SESSION_PROJECTS[$i]}" == "$proj" ]]; then
                order+=("$i")
                count=$(( count + 1 ))
            fi
        done
        GROUP_NAMES+=("$proj")
        GROUP_STARTS+=("$start")
        GROUP_COUNTS+=("$count")
        GROUP_COUNT=$(( GROUP_COUNT + 1 ))
    done

    # Reorder all SESSION_* arrays according to order[]
    local -a nw_FILES=() nw_IDS=() nw_TYPES=() nw_ELAPSED=() nw_DIRS=()
    local -a nw_LAST_MSG=() nw_TIMESTAMPS=() nw_PROJECTS=() nw_BRANCHES=()
    local -a nw_VERSIONS=() nw_FIRST_MSG=() nw_MSG_COUNTS=() nw_CWDS=() nw_EPOCH=()

    for idx in "${order[@]}"; do
        nw_FILES+=("${SESSION_FILES[$idx]}")
        nw_IDS+=("${SESSION_IDS[$idx]}")
        nw_TYPES+=("${SESSION_TYPES[$idx]}")
        nw_ELAPSED+=("${SESSION_ELAPSED[$idx]}")
        nw_DIRS+=("${SESSION_DIRS[$idx]}")
        nw_LAST_MSG+=("${SESSION_LAST_MSG[$idx]}")
        nw_TIMESTAMPS+=("${SESSION_TIMESTAMPS[$idx]}")
        nw_PROJECTS+=("${SESSION_PROJECTS[$idx]}")
        nw_BRANCHES+=("${SESSION_BRANCHES[$idx]}")
        nw_VERSIONS+=("${SESSION_VERSIONS[$idx]}")
        nw_FIRST_MSG+=("${SESSION_FIRST_MSG[$idx]}")
        nw_MSG_COUNTS+=("${SESSION_MSG_COUNTS[$idx]}")
        nw_CWDS+=("${SESSION_CWDS[$idx]}")
        nw_EPOCH+=("${SESSION_EPOCH[$idx]}")
    done

    SESSION_FILES=("${nw_FILES[@]}")
    SESSION_IDS=("${nw_IDS[@]}")
    SESSION_TYPES=("${nw_TYPES[@]}")
    SESSION_ELAPSED=("${nw_ELAPSED[@]}")
    SESSION_DIRS=("${nw_DIRS[@]}")
    SESSION_LAST_MSG=("${nw_LAST_MSG[@]}")
    SESSION_TIMESTAMPS=("${nw_TIMESTAMPS[@]}")
    SESSION_PROJECTS=("${nw_PROJECTS[@]}")
    SESSION_BRANCHES=("${nw_BRANCHES[@]}")
    SESSION_VERSIONS=("${nw_VERSIONS[@]}")
    SESSION_FIRST_MSG=("${nw_FIRST_MSG[@]}")
    SESSION_MSG_COUNTS=("${nw_MSG_COUNTS[@]}")
    SESSION_CWDS=("${nw_CWDS[@]}")
    SESSION_EPOCH=("${nw_EPOCH[@]}")
}

# ── Search with BM25 scoring ──────────────────────────────────────────────
# Searches all user messages in each session's .jsonl file.
# Scores results using simplified BM25: TF * IDF component.
# Results are sorted by score descending; non-matching sessions are hidden.

search_sessions() {
    local query="$1"
    if [[ -z "$query" ]]; then
        return
    fi

    local query_lower
    query_lower=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')

    # Split query into terms
    local -a terms=()
    for word in $query_lower; do
        [[ -n "$word" ]] && terms+=("$word")
    done
    if [[ ${#terms[@]} -eq 0 ]]; then
        return
    fi

    local total_docs=$SESSION_COUNT
    if (( total_docs == 0 )); then
        return
    fi

    # For each session, compute BM25 score by searching full .jsonl content
    local -a scored_indices=()
    local -a scored_values=()
    local k1=1200  # BM25 k1 * 1000 (integer math, 1.2 → 1200)
    local b=750    # BM25 b * 1000 (0.75 → 750)

    # Compute average document length (word count of all user messages)
    local total_words=0
    local -a doc_lengths=()
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local wc
        wc=$(jq -s -r '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | split(" ") | length' \
            "${SESSION_FILES[$i]}" 2>/dev/null) || wc=0
        doc_lengths+=("$wc")
        total_words=$(( total_words + wc ))
    done
    local avg_dl=$(( total_words / (total_docs > 0 ? total_docs : 1) ))
    (( avg_dl == 0 )) && avg_dl=1

    # Count document frequency for each term (how many sessions contain it)
    local -a df=()
    for (( t=0; t<${#terms[@]}; t++ )); do
        local term_df=0
        for (( i=0; i<SESSION_COUNT; i++ )); do
            if jq -s -e --arg q "${terms[$t]}" \
                '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | ascii_downcase | test($q)' \
                "${SESSION_FILES[$i]}" >/dev/null 2>&1; then
                term_df=$(( term_df + 1 ))
            fi
        done
        df+=("$term_df")
    done

    # Score each session
    for (( i=0; i<SESSION_COUNT; i++ )); do
        local score=0
        local dl="${doc_lengths[$i]}"
        local matched=false

        # Get all user message text for this session (lowercase)
        local all_text
        all_text=$(jq -s -r '[.[] | select(.type == "user") | .message.content // ""] | join(" ") | ascii_downcase' \
            "${SESSION_FILES[$i]}" 2>/dev/null) || all_text=""

        for (( t=0; t<${#terms[@]}; t++ )); do
            local term="${terms[$t]}"
            local tdf="${df[$t]}"

            # Term frequency: count occurrences
            local tf=0
            if [[ -n "$all_text" ]]; then
                # Count non-overlapping occurrences
                local stripped="${all_text//$term/}"
                local term_len=${#term}
                if (( term_len > 0 )); then
                    tf=$(( (${#all_text} - ${#stripped}) / term_len ))
                fi
            fi

            if (( tf > 0 )); then
                matched=true

                # IDF = ln((N - df + 0.5) / (df + 0.5)) * 1000
                # Simplified: higher when term is rarer
                local idf
                if (( tdf == 0 )); then
                    idf=1000
                else
                    # (N - df) / df * 1000 as approximation
                    idf=$(( (total_docs - tdf) * 1000 / tdf ))
                fi
                (( idf < 100 )) && idf=100

                # BM25 TF component: tf * (k1 + 1000) / (tf * 1000 + k1 * (1000 - b + b * dl * 1000 / avg_dl) / 1000)
                # Simplified integer approximation:
                local norm=$(( 1000 - b + b * dl / avg_dl ))
                local denom=$(( tf * 1000 + k1 * norm / 1000 ))
                local tf_score=0
                if (( denom > 0 )); then
                    tf_score=$(( tf * (k1 + 1000) * 1000 / denom ))
                fi

                score=$(( score + tf_score * idf / 1000 ))
            fi
        done

        if $matched; then
            scored_indices+=("$i")
            scored_values+=("$score")
        fi
    done

    # Sort by score descending — rebuild arrays in score order
    local count=${#scored_indices[@]}
    if (( count == 0 )); then
        # No matches — clear everything
        SESSION_FILES=()
        SESSION_IDS=()
        SESSION_TYPES=()
        SESSION_ELAPSED=()
        SESSION_DIRS=()
        SESSION_LAST_MSG=()
        SESSION_TIMESTAMPS=()
        SESSION_PROJECTS=()
        SESSION_BRANCHES=()
        SESSION_VERSIONS=()
        SESSION_FIRST_MSG=()
        SESSION_MSG_COUNTS=()
        SESSION_CWDS=()
        SESSION_EPOCH=()
        SESSION_COUNT=0
        return
    fi

    # Bubble sort indices by score (small N, fine for ~100 sessions)
    for (( a=0; a<count-1; a++ )); do
        for (( c=0; c<count-a-1; c++ )); do
            if (( scored_values[c] < scored_values[c+1] )); then
                local tmp_i="${scored_indices[$c]}"
                scored_indices[$c]="${scored_indices[$((c+1))]}"
                scored_indices[$((c+1))]="$tmp_i"
                local tmp_s="${scored_values[$c]}"
                scored_values[$c]="${scored_values[$((c+1))]}"
                scored_values[$((c+1))]="$tmp_s"
            fi
        done
    done

    # Rebuild arrays in sorted order
    local -a new_FILES=() new_IDS=() new_TYPES=() new_ELAPSED=() new_DIRS=()
    local -a new_LAST_MSG=() new_TIMESTAMPS=() new_PROJECTS=() new_BRANCHES=()
    local -a new_VERSIONS=() new_FIRST_MSG=() new_MSG_COUNTS=() new_CWDS=() new_EPOCH=()

    for (( x=0; x<count; x++ )); do
        local idx="${scored_indices[$x]}"
        new_FILES+=("${SESSION_FILES[$idx]}")
        new_IDS+=("${SESSION_IDS[$idx]}")
        new_TYPES+=("${SESSION_TYPES[$idx]}")
        new_ELAPSED+=("${SESSION_ELAPSED[$idx]}")
        new_DIRS+=("${SESSION_DIRS[$idx]}")
        new_LAST_MSG+=("${SESSION_LAST_MSG[$idx]}")
        new_TIMESTAMPS+=("${SESSION_TIMESTAMPS[$idx]}")
        new_PROJECTS+=("${SESSION_PROJECTS[$idx]}")
        new_BRANCHES+=("${SESSION_BRANCHES[$idx]}")
        new_VERSIONS+=("${SESSION_VERSIONS[$idx]}")
        new_FIRST_MSG+=("${SESSION_FIRST_MSG[$idx]}")
        new_MSG_COUNTS+=("${SESSION_MSG_COUNTS[$idx]}")
        new_CWDS+=("${SESSION_CWDS[$idx]}")
        new_EPOCH+=("${SESSION_EPOCH[$idx]}")
    done

    SESSION_FILES=("${new_FILES[@]}")
    SESSION_IDS=("${new_IDS[@]}")
    SESSION_TYPES=("${new_TYPES[@]}")
    SESSION_ELAPSED=("${new_ELAPSED[@]}")
    SESSION_DIRS=("${new_DIRS[@]}")
    SESSION_LAST_MSG=("${new_LAST_MSG[@]}")
    SESSION_TIMESTAMPS=("${new_TIMESTAMPS[@]}")
    SESSION_PROJECTS=("${new_PROJECTS[@]}")
    SESSION_BRANCHES=("${new_BRANCHES[@]}")
    SESSION_VERSIONS=("${new_VERSIONS[@]}")
    SESSION_FIRST_MSG=("${new_FIRST_MSG[@]}")
    SESSION_MSG_COUNTS=("${new_MSG_COUNTS[@]}")
    SESSION_CWDS=("${new_CWDS[@]}")
    SESSION_EPOCH=("${new_EPOCH[@]}")
    SESSION_COUNT=$count
}

# ── Session Launch (fallback for non-tmux) ─────────────────────────────────
launch_session_direct() {
    local sid="$1"
    local cwd="$2"

    tput rmcup
    tput cnorm
    if [[ -n "$ORIG_STTY" ]]; then
        stty "$ORIG_STTY" 2>/dev/null || true
    fi
    clear_screen

    printf "${FG_GRAY}ssread: session ${sid:0:8}${RESET}\n\n"

    if [[ -n "$cwd" && -d "$cwd" ]]; then
        cd "$cwd"
    fi

    set +e
    claude --resume "$sid"
    set -e

    tput smcup
    tput civis
    stty -echo -icanon min 1 time 0
    clear_screen
}

# ── Drawing ────────────────────────────────────────────────────────────────
draw_border() {
    move_to 1 1
    printf "┌"
    printf "%0.s─" $(seq 1 "$LEFT_WIDTH")
    printf "┬"
    printf "%0.s─" $(seq 1 "$RIGHT_WIDTH")
    printf "┐"

    draw_vline 1 2 $(( TERM_ROWS - 2 )) "│"
    draw_vline $(( LEFT_WIDTH + 2 )) 2 $(( TERM_ROWS - 2 )) "│"
    draw_vline $(( TERM_COLS )) 2 $(( TERM_ROWS - 2 )) "│"

    move_to $(( TERM_ROWS - 1 )) 1
    printf "└"
    printf "%0.s─" $(seq 1 "$LEFT_WIDTH")
    printf "┴"
    printf "%0.s─" $(seq 1 "$RIGHT_WIDTH")
    printf "┘"
}

draw_left_header() {
    local active_count
    active_count=$(tmux_active_count)
    local title
    if [[ -n "$SEARCH_ACTIVE" ]]; then
        title=" Search: \"$SEARCH_ACTIVE\" ($SESSION_COUNT results)"
    elif (( active_count > 0 )); then
        title=" Sessions ($SESSION_COUNT)  ${FG_GREEN}▸ $active_count running"
    else
        title=" Sessions ($SESSION_COUNT)"
    fi
    print_at_styled 1 2 "$LEFT_WIDTH" "${BOLD}${FG_CYAN}" "$title"
}

draw_right_header() {
    print_at_styled 1 $(( LEFT_WIDTH + 3 )) "$RIGHT_WIDTH" "${BOLD}${FG_CYAN}" " Detail"
}

draw_session_list() {
    # Build a flat display list: each entry is either a group header or a session.
    # display_types[n] = "group" | "session"
    # display_indices[n] = group index (for group) or session index (for session)
    local -a display_types=()
    local -a display_indices=()

    if [[ -n "$SEARCH_ACTIVE" ]] || (( GROUP_COUNT == 0 )); then
        # In search mode or no groups: flat list, no headers
        for (( i=0; i<SESSION_COUNT; i++ )); do
            display_types+=("session")
            display_indices+=("$i")
        done
    else
        for (( g=0; g<GROUP_COUNT; g++ )); do
            display_types+=("group")
            display_indices+=("$g")
            local gstart="${GROUP_STARTS[$g]}"
            local gcount="${GROUP_COUNTS[$g]}"
            for (( s=0; s<gcount; s++ )); do
                display_types+=("session")
                display_indices+=("$(( gstart + s ))")
            done
        done
    fi

    local display_total=${#display_types[@]}

    # Map SELECTED (session index) to display index for scroll calculation
    local selected_display=0
    for (( d=0; d<display_total; d++ )); do
        if [[ "${display_types[$d]}" == "session" && "${display_indices[$d]}" -eq "$SELECTED" ]]; then
            selected_display=$d
            break
        fi
    done

    # Scroll: each item takes 1 line (group header) or 2 lines (session)
    # Calculate total row heights for scroll
    local visible_rows=$(( TERM_ROWS - 4 ))

    # Adjust scroll offset (in display indices) so selected is visible
    if (( selected_display < SCROLL_OFFSET )); then
        SCROLL_OFFSET=$selected_display
        # Include group header above if the selected is first in its group
        if (( SCROLL_OFFSET > 0 )) && [[ "${display_types[$((SCROLL_OFFSET-1))]}" == "group" ]]; then
            SCROLL_OFFSET=$(( SCROLL_OFFSET - 1 ))
        fi
    fi

    # Forward scroll: render from SCROLL_OFFSET until selected is visible
    local test_row=0
    local need_scroll=true
    while $need_scroll; do
        test_row=0
        for (( d=SCROLL_OFFSET; d<display_total; d++ )); do
            if [[ "${display_types[$d]}" == "group" ]]; then
                test_row=$(( test_row + 1 ))
            else
                test_row=$(( test_row + 2 ))
            fi
            if (( d == selected_display )); then
                if (( test_row <= visible_rows )); then
                    need_scroll=false
                else
                    SCROLL_OFFSET=$(( SCROLL_OFFSET + 1 ))
                fi
                break
            fi
        done
        # Safety: if we've scrolled past everything
        if (( SCROLL_OFFSET >= display_total )); then
            SCROLL_OFFSET=$(( display_total > 0 ? display_total - 1 : 0 ))
            break
        fi
    done

    # Render
    local row=2
    for (( d=SCROLL_OFFSET; d<display_total && row < TERM_ROWS - 1; d++ )); do
        if [[ "${display_types[$d]}" == "group" ]]; then
            local g="${display_indices[$d]}"
            local gname="${GROUP_NAMES[$g]}"
            local gcount="${GROUP_COUNTS[$g]}"
            local header
            header=$(printf " ┈ %s (%d)" "$gname" "$gcount")
            print_at_styled "$row" 2 "$LEFT_WIDTH" "${BOLD}${FG_BLUE}" "$header"
            row=$(( row + 1 ))
        else
            local i="${display_indices[$d]}"
            local sid_short="${SESSION_IDS[$i]:0:8}"
            local etype="${SESSION_TYPES[$i]}"
            local elapsed="${SESSION_ELAPSED[$i]}"
            local last_msg="${SESSION_LAST_MSG[$i]}"

            local run_mark=""
            if is_session_active "${SESSION_IDS[$i]}"; then
                run_mark=" ▸"
            fi

            local line1
            if (( i == SELECTED )); then
                line1=$(printf " ▶ %-8s  %-4s  %-7s%s" "$sid_short" "$etype" "$elapsed" "$run_mark")
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${BOLD}${REV}${FG_WHITE}" "$line1"
            else
                if [[ -n "$run_mark" ]]; then
                    line1=$(printf "   %-8s  %-4s  %-7s%s" "$sid_short" "$etype" "$elapsed" "$run_mark")
                    print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_GREEN}" "$line1"
                else
                    line1=$(printf "   %-8s  %-4s  %s" "$sid_short" "$etype" "$elapsed")
                    print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_WHITE}" "$line1"
                fi
            fi
            row=$(( row + 1 ))

            local line2="     ${last_msg}"
            if (( i == SELECTED )); then
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${REV}${FG_GRAY}" "$line2"
            else
                print_at_styled "$row" 2 "$LEFT_WIDTH" "${FG_GRAY}" "$line2"
            fi
            row=$(( row + 1 ))
        fi
    done

    while (( row < TERM_ROWS - 1 )); do
        print_at "$row" 2 "$LEFT_WIDTH" ""
        row=$(( row + 1 ))
    done
}

draw_detail_panel() {
    local col=$(( LEFT_WIDTH + 3 ))
    local width=$(( RIGHT_WIDTH - 2 ))
    local row=2

    if (( SESSION_COUNT == 0 )); then
        print_at_styled "$row" "$col" "$width" "${FG_GRAY}" "  No sessions found."
        row=$(( row + 1 ))
        while (( row < TERM_ROWS - 1 )); do
            print_at "$row" "$col" "$width" ""
            row=$(( row + 1 ))
        done
        return
    fi

    local i=$SELECTED
    local sid="${SESSION_IDS[$i]}"
    local etype="${SESSION_TYPES[$i]}"
    local project="${SESSION_PROJECTS[$i]}"
    local branch="${SESSION_BRANCHES[$i]}"
    local cwd="${SESSION_CWDS[$i]}"
    local ts="${SESSION_TIMESTAMPS[$i]}"
    local ver="${SESSION_VERSIONS[$i]}"
    local first_msg="${SESSION_FIRST_MSG[$i]}"
    local last_msg="${SESSION_LAST_MSG[$i]}"
    local msg_count="${SESSION_MSG_COUNTS[$i]}"

    print_at_styled "$row" "$col" "$width" "${BOLD}${FG_YELLOW}" "  Session"
    row=$(( row + 1 ))

    if is_session_active "$sid"; then
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid  ${FG_GREEN}▸ running"
    else
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  $sid"
    fi
    row=$(( row + 2 ))

    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Project   ${RESET}${FG_WHITE}$project"
    row=$(( row + 1 ))

    if [[ -n "$branch" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Branch    ${RESET}${FG_GREEN}$branch"
        row=$(( row + 1 ))
    fi

    if [[ -n "$cwd" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  CWD       ${RESET}${FG_WHITE}$cwd"
        row=$(( row + 1 ))
    fi

    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Type      ${RESET}${FG_WHITE}$etype"
    row=$(( row + 1 ))
    if [[ -n "$ver" ]]; then
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Version   ${RESET}${FG_WHITE}$ver"
        row=$(( row + 1 ))
    fi

    if [[ -n "$ts" ]]; then
        local formatted
        formatted=$(format_datetime "$ts")
        print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Started   ${RESET}${FG_WHITE}$formatted"
        row=$(( row + 1 ))
    fi

    print_at_styled "$row" "$col" "$width" "${FG_CYAN}" "  Messages  ${RESET}${FG_WHITE}$msg_count user messages"
    row=$(( row + 2 ))

    print_at_styled "$row" "$col" "$width" "${BOLD}${FG_MAGENTA}" "  ── First Message ──"
    row=$(( row + 1 ))
    local remaining="$first_msg"
    local line_width=$(( width - 4 ))
    while [[ -n "$remaining" ]] && (( row < TERM_ROWS - 8 )); do
        print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  ${remaining:0:$line_width}"
        remaining="${remaining:$line_width}"
        row=$(( row + 1 ))
    done
    row=$(( row + 1 ))

    if [[ "$first_msg" != "$last_msg" ]] && [[ -n "$last_msg" ]]; then
        print_at_styled "$row" "$col" "$width" "${BOLD}${FG_MAGENTA}" "  ── Last Message ──"
        row=$(( row + 1 ))
        remaining="$last_msg"
        while [[ -n "$remaining" ]] && (( row < TERM_ROWS - 3 )); do
            print_at_styled "$row" "$col" "$width" "${FG_WHITE}" "  ${remaining:0:$line_width}"
            remaining="${remaining:$line_width}"
            row=$(( row + 1 ))
        done
    fi

    while (( row < TERM_ROWS - 1 )); do
        print_at "$row" "$col" "$width" ""
        row=$(( row + 1 ))
    done
}

draw_status_bar() {
    local bar_row=$TERM_ROWS
    move_to "$bar_row" 1
    if $SEARCH_MODE; then
        printf "${REV}${FG_WHITE} /${SEARCH_QUERY}█%-$(( TERM_COLS - ${#SEARCH_QUERY} - 3 ))s${RESET}" " Enter: Search  Esc: Cancel"
    elif [[ -n "$SEARCH_ACTIVE" ]]; then
        local bar_text=" ↑↓ Navigate  Enter: Open  Esc: Clear search  /: New search  r: Refresh"
        printf "${BG_DARK}${FG_WHITE}%-${TERM_COLS}s${RESET}" "$bar_text"
    else
        local bar_text=" ↑↓ Navigate  Enter: Open  Tab: Next window  q: Quit  Q: Quit all  /: Search  r: Refresh"
        printf "${BG_DARK}${FG_WHITE}%-${TERM_COLS}s${RESET}" "$bar_text"
    fi
}

draw_loading() {
    clear_screen
    local mid_row=$(( TERM_ROWS / 2 ))
    local mid_col=$(( TERM_COLS / 2 - 12 ))
    move_to "$mid_row" "$mid_col"
    printf "${BOLD}${FG_CYAN}ssread${RESET}${FG_GRAY} loading sessions...${RESET}"
}

render() {
    get_dimensions
    refresh_active_windows
    local buf
    buf=$(
        draw_border
        draw_left_header
        draw_right_header
        draw_session_list
        draw_detail_panel
        draw_status_bar
    )
    printf "%s" "$buf"
}

# ── Input Handling ─────────────────────────────────────────────────────────
_KEY=""

read_key() {
    _KEY=""
    local c
    IFS= read -rsn1 c || true
    if [[ "$c" == $'\x1b' ]]; then
        local seq=""
        IFS= read -rsn1 -t 1 seq || true
        if [[ "$seq" == "[" ]]; then
            local code=""
            IFS= read -rsn1 -t 1 code || true
            _KEY="ESC[${code}"
        else
            _KEY="ESC"
        fi
    elif [[ "$c" == $'\t' ]]; then
        _KEY="TAB"
    elif [[ "$c" == "" ]]; then
        _KEY="ENTER"
    else
        _KEY="$c"
    fi
}

handle_search_input() {
    case "$_KEY" in
        ENTER)
            SEARCH_MODE=false
            if [[ -n "$SEARCH_QUERY" ]]; then
                SEARCH_ACTIVE="$SEARCH_QUERY"
                SELECTED=0
                SCROLL_OFFSET=0
                draw_loading
                load_sessions
                search_sessions "$SEARCH_ACTIVE"
                group_sessions
            fi
            ;;
        ESC)
            SEARCH_MODE=false
            if [[ -n "$SEARCH_ACTIVE" ]]; then
                # Clear search and reload all sessions
                SEARCH_QUERY=""
                SEARCH_ACTIVE=""
                SELECTED=0
                SCROLL_OFFSET=0
                load_sessions
                group_sessions
            fi
            SEARCH_QUERY=""
            ;;
        $'\x7f'|$'\b')
            SEARCH_QUERY="${SEARCH_QUERY%?}"
            ;;
        *)
            if [[ ${#_KEY} -eq 1 ]] && [[ "$_KEY" =~ [[:print:]] ]]; then
                SEARCH_QUERY="${SEARCH_QUERY}${_KEY}"
            fi
            ;;
    esac
}

handle_input() {
    read_key

    if $SEARCH_MODE; then
        handle_search_input
        return
    fi

    case "$_KEY" in
        "ESC[A"|k)
            if (( SELECTED > 0 )); then
                SELECTED=$(( SELECTED - 1 ))
            fi
            ;;
        "ESC[B"|j)
            if (( SELECTED < SESSION_COUNT - 1 )); then
                SELECTED=$(( SELECTED + 1 ))
            fi
            ;;
        ENTER)
            if (( SESSION_COUNT > 0 )); then
                local sid="${SESSION_IDS[$SELECTED]}"
                local cwd="${SESSION_CWDS[$SELECTED]}"

                # Check if session is already running in a tmux window
                local existing_window
                existing_window=$(tmux_find_session_window "$sid")

                if [[ -n "$existing_window" ]]; then
                    # Switch to existing window
                    tmux_switch_to_window "$existing_window"
                else
                    # Launch in new tmux window
                    tmux_launch_session "$sid" "$cwd"
                fi
            fi
            ;;
        TAB)
            # Switch to next tmux window
            if [[ -n "${TMUX:-}" ]]; then
                tmux next-window 2>/dev/null || true
            fi
            ;;
        q)
            exit 0
            ;;
        Q)
            # Kill all claude windows then quit
            tmux_kill_all_sessions
            exit 0
            ;;
        /)
            SEARCH_MODE=true
            SEARCH_QUERY=""
            ;;
        ESC)
            if [[ -n "$SEARCH_ACTIVE" ]]; then
                SEARCH_QUERY=""
                SEARCH_ACTIVE=""
                SELECTED=0
                SCROLL_OFFSET=0
                load_sessions
                group_sessions
            fi
            ;;
        r)
            SELECTED=0
            SCROLL_OFFSET=0
            ACTIVE_WINDOWS_LAST_REFRESH=0
            draw_loading
            load_sessions
            group_sessions
            ;;
        g)
            SELECTED=0
            SCROLL_OFFSET=0
            ;;
        G)
            if (( SESSION_COUNT > 0 )); then
                SELECTED=$(( SESSION_COUNT - 1 ))
            fi
            ;;
    esac
}

# ── Self-Test ──────────────────────────────────────────────────────────────
run_tests() {
    local ssread_dir
    ssread_dir="$(cd "$(dirname "$0")" && pwd)"
    local test_file="$ssread_dir/tests/test_ssread.sh"

    if [[ ! -f "$test_file" ]]; then
        echo "Error: test file not found at $test_file"
        exit 1
    fi

    if ! command -v bats &>/dev/null; then
        echo "Error: bats is required to run tests."
        echo "  brew install bats-core  (macOS)"
        echo "  apt install bats        (Ubuntu/Debian)"
        exit 1
    fi

    exec bats "$test_file"
}

# ── Main ───────────────────────────────────────────────────────────────────
main() {
    # Handle --test before anything else
    if [[ "${1:-}" == "--test" ]]; then
        run_tests
    fi

    check_dependencies

    if [[ ! -d "$CLAUDE_PROJECTS_DIR" ]]; then
        echo "Error: $CLAUDE_PROJECTS_DIR not found."
        echo "No Claude Code session data available."
        exit 1
    fi

    # Bootstrap into tmux if not already inside
    ensure_tmux_session "$@"

    get_tmux_session_name
    setup_terminal
    get_dimensions
    draw_loading
    load_sessions
    group_sessions
    clear_screen

    while true; do
        render
        handle_input
    done
}

main "$@"
